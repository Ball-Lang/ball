                                if ((BallDyn(result)["kind"s] == "return"s)) return result;
                                if ((BallDyn(BallDyn(result)["label"s]).has_value() && !BallDyn(result)["label"s].empty())) return result;
                                if ((BallDyn(result)["kind"s] == "break"s)) break;
                            }
                        }
                    }
                    return BallDyn();
                }
                // Default: iterate as MapEntry {key, value}
                BallList entries;
                const BallMap* m = scope_map_cptr(iterVal._val);
                if (m) {
                    for (auto& [k, v] : *m) {
                        if (k.find("__") == 0 || k == "type_args") continue;
                        entries.push_back(std::any(BallMap{{"key", std::any(k)}, {"value", v}}));
                    }
                }
                iterVal = BallDyn(entries);
            } else if (ball_is_string(iterVal)) {
                BallList chars;
                std::string s = static_cast<std::string>(iterVal);
