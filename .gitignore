# ============================================================
# Ball Programming Language — .gitignore
# ============================================================

# ----------------------------------
# OS & IDE
# ----------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
# IntelliJ/Melos per-package module files (melos bootstrap generates
# melos_<pkg>.iml). IDE artifacts — never commit; keeps them out of the
# auto-generated release PR (create-pull-request does `git add -A`).
*.iml

# ----------------------------------
# Dart
# ----------------------------------
.dart_tool/
.packages
pubspec.lock
# Commit the Dart workspace lock so CI resolves the SAME, known-good dependency
# versions as local. Without it, `dart pub get` fresh-resolves newer deps, which
# has repeatedly broken CI (analyzer error churn, BallDouble/num, formatter drift)
# while passing locally. The workspace root is the repo root (see /pubspec.yaml).
!/pubspec.lock
build/

# Coverage artifacts (lcov from tools/coverage_dart.dart; regenerated, not committed)
coverage/

# ----------------------------------
# C++ Build
# ----------------------------------
cpp/build/
cpp/build*/
CMakeUserPresets.json

# C++ test logs at project level
cpp/test_engine_err.txt
cpp/test_engine_out.txt

# ----------------------------------
# Website
# ----------------------------------
website/build/
website/.dart_tool/

# Generated by jaspr_builder (regenerated on build)
website/lib/main.server.options.dart
website/lib/main.client.options.dart

# ----------------------------------
# Examples — temporary output
# ----------------------------------
examples/compiled_out.txt
examples/orig_out.txt
examples/strings_math.dart

# ----------------------------------
# Temporary project files
# ----------------------------------
dart_test_out.txt
IMPLEMENTATION_PLAN.md

# ----------------------------------
# Python
# ----------------------------------
__pycache__/
*.pyc
*.pyo

# ----------------------------------
# Node / TypeScript
# ----------------------------------
node_modules/
dist/

# ----------------------------------
# Java
# ----------------------------------
*.class
target/

# ----------------------------------
# C# / .NET
# ----------------------------------
csharp/**/bin/
csharp/**/obj/
*.user

# ----------------------------------
# Local agent / tooling state (per-machine, may leak absolute paths)
# ----------------------------------
.omc/
**/.omc/
.sisyphus/boulder.json
.claude/scheduled_tasks.lock
.claude/worktrees/
.claude/settings.local.json

# ----------------------------------
# Transient logs / scratch output
# ----------------------------------
*.log
test_output.txt
engine_test.log
cpp/ci-build-test/

# Compiled upstream-conformance program (built ad hoc / in CI).
/ball_conformance
/ball_conformance.exe
cpp/build-conformance/

# conformance failure analysis scratch
.conf_failing_list.txt
.conf_failing_detail.txt

# Ball generated build artifact: output of
# dart/compiler/tool/compile_ball_protobuf_cpp.dart, regenerated on demand and
# never read as a committed input. Kept out of git (1.2 MB). See issue #27.
dart/shared/ball_protobuf_program.json
