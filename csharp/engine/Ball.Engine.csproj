<Project Sdk="Microsoft.NET.Sdk">

  <!--
    csharp/engine: self-hosted Ball engine wrapper (issue #383). The engine is
    the reference engine compiled from dart/self_host/engine.ball.pb through the
    Ball -> C# compiler into src/CompiledEngine.cs (a GITIGNORED generated
    artifact, regenerated by csharp/engine/tool), plus this thin native wrapper
    (loader + the ball_proto access patterns live in Ball.Shared's BallProto).

    Feature-flag arrangement (the C# analog of Rust's `self_host` cargo
    feature): CompiledEngine.cs is EXCLUDED from the default build and the
    generated-file-referencing driver code is gated behind the SELF_HOST
    compilation symbol, so the DEFAULT build stays green even when the generated
    file is absent (fresh checkout) or does not yet compile (the self-host
    grind, #383). Turn it on with `-p:SelfHost=true`.
  -->

  <PropertyGroup Condition="'$(SelfHost)' == 'true'">
    <DefineConstants>$(DefineConstants);SELF_HOST</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="test/**/*.cs" />
    <!-- tool/ is a sibling console project (the regenerator); exclude it from
         this project's own compile items. -->
    <Compile Remove="tool/**/*.cs" />
    <!-- Generated self-hosted engine: off by default; included only for the
         SelfHost build so the default build never depends on it. -->
    <Compile Remove="src/CompiledEngine.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(SelfHost)' == 'true'">
    <Compile Include="src/CompiledEngine.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../shared/Ball.Shared.csproj" />
  </ItemGroup>

</Project>
