    BallDyn /* future */ _tryOperatorOverride(auto function, auto input) {
        auto op = BallDyn(_stdFunctionToOperator())[function];
        if ((!BallDyn(op).has_value() || !(ball_is_map(input)))) {
            return BallDyn();
        }
        auto left = BallDyn();
        auto right = BallDyn();
        if ((function == "index"s)) {
            (left = BallDyn(input)["target"s]);
            (right = BallDyn(input)["index"s]);
        } else {
            (left = BallDyn(input)["left"s]);
            (right = BallDyn(input)["right"s]);
        }
        if ((!(ball_is_map(left)) || (!(left.count("__type__"s) > 0)))) {
            return BallDyn();
        }
        auto typeName = BallDyn(left)["__type__"s];
        auto colonIdx = typeName.indexOf(":"s);
        auto modPart = (BallDyn((colonIdx >= 0LL) ? BallDyn(typeName.substr(0LL, colonIdx - 0LL)) : BallDyn(_currentModule)));
        auto current = left;
        while (BallDyn(current).has_value()) {
            auto curType = BallDyn(current)["__type__"s];
            if (BallDyn(curType).has_value()) {
                auto cColonIdx = curType.indexOf(":"s);
                auto cModPart = (BallDyn((cColonIdx >= 0LL) ? BallDyn(curType.substr(0LL, cColonIdx - 0LL)) : BallDyn(modPart)));
                auto cTypeName = (BallDyn((cColonIdx >= 0LL) ? BallDyn(curType) : BallDyn(((ball_to_string(cModPart) + ":"s) + ball_to_string(curType)))));
                auto methodKey = ((((ball_to_string(cModPart) + "."s) + ball_to_string(cTypeName)) + "."s) + ball_to_string(op));
                auto method = BallDyn(_functions)[methodKey];
                if (BallDyn(method).has_value()) {
                    auto methodInput = std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("self"s)}, {"value", std::any(left)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("other"s)}, {"value", std::any(right)}})}};
                    return _callFunction(cModPart, method, methodInput);
                }
            }
            auto super_ = BallDyn(current)["__super__"s];
            (current = (BallDyn(ball_is_map(super_) ? BallDyn(super_) : BallDyn(BallDyn()))));
        }
        return BallDyn();
    }
    // Operator-overridable function set (replaces broken _stdFunctionToOperator map)
    bool _isOperatorOverridable(const std::string& fn) {
        static const std::unordered_set<std::string> ops = {
            "equals", "not_equals", "add", "subtract", "multiply",
            "divide", "divide_double", "modulo", "less_than",
            "greater_than", "lte", "gte", "index"
        };
        return ops.count(fn) > 0;
    }
    BallDyn /* future */ _callBaseFunction(auto module, auto function, auto input) {
        std::string fn = ball_to_string(function);
        if (_isOperatorOverridable(fn)) {
            auto override = _tryOperatorOverride(function, input);
            if (BallDyn(override).has_value()) {
                return override;
            }
        }
        // Direct dispatch for std functions
        return _dispatchStdFunction(fn, input);
    }
    BallDyn _dispatchStdFunction(const std::string& fn, BallDyn input) {
        // --- print / IO ---
        if (fn == "print") return _stdPrint(input);
        if (fn == "print_error") { stderr_(ball_to_string(input)); return BallDyn(); }
        // --- arithmetic ---
        if (fn == "add") return _stdAdd(input);
        if (fn == "subtract") return _stdBinary(input, [](auto a, auto b){ return a - b; });
        if (fn == "multiply") return _stdBinary(input, [](auto a, auto b){ return a * b; });
        if (fn == "divide") return _stdBinaryInt(input, [](auto a, auto b){ return a / b; });
        if (fn == "divide_double") return _stdBinaryDouble(input, [](auto a, auto b){ return static_cast<double>(a) / b; });
        if (fn == "modulo") return _stdBinaryInt(input, [](auto a, auto b) -> int64_t {
            auto r = a % b; return r < 0 ? r + (b < 0 ? -b : b) : r;
        });
        if (fn == "negate") return _stdUnaryNum(input, [](auto v){ return -v; });
        // --- comparison ---
        if (fn == "equals") return _stdBinaryAny(input, [](auto a, auto b){ return a == b; });
        if (fn == "not_equals") return _stdBinaryAny(input, [](auto a, auto b){ return a != b; });
        if (fn == "less_than") return _stdBinaryComp(input, [](auto a, auto b){ return a < b; });
        if (fn == "greater_than") return _stdBinaryComp(input, [](auto a, auto b){ return a > b; });
        if (fn == "lte") return _stdBinaryComp(input, [](auto a, auto b){ return a <= b; });
        if (fn == "gte") return _stdBinaryComp(input, [](auto a, auto b){ return a >= b; });
        // --- logic ---
        if (fn == "and") return _stdBinaryBool(input, [](auto a, auto b){ return a && b; });
        if (fn == "or") return _stdBinaryBool(input, [](auto a, auto b){ return a || b; });
        if (fn == "not") return _stdNot(input);
        // --- bitwise ---
        if (fn == "bitwise_and") return _stdBinaryInt(input, [](auto a, auto b){ return a & b; });
        if (fn == "bitwise_or") return _stdBinaryInt(input, [](auto a, auto b){ return a | b; });
        if (fn == "bitwise_xor") return _stdBinaryInt(input, [](auto a, auto b){ return a ^ b; });
        if (fn == "bitwise_not") { auto val = _extractUnaryArg(input); return BallDyn(~_toInt(val)); }
        if (fn == "left_shift") return _stdBinaryInt(input, [](auto a, auto b){ return a << b; });
        if (fn == "right_shift") return _stdBinaryInt(input, [](auto a, auto b){ return a >> b; });
        if (fn == "unsigned_right_shift") return _stdBinaryInt(input, [](auto a, auto b){ return a >> b; });
        // --- increment/decrement ---
        if (fn == "pre_increment") return _extractUnaryArg(input) + 1LL;
        if (fn == "pre_decrement") return _extractUnaryArg(input) - 1LL;
        if (fn == "post_increment") return _extractUnaryArg(input) + 1LL;
        if (fn == "post_decrement") return _extractUnaryArg(input) - 1LL;
        // --- string ---
        if (fn == "concat") return _stdConcat(input);
        if (fn == "length") return _stdLength(input);
        if (fn == "to_string" || fn == "int_to_string" || fn == "double_to_string")
            return _stdConvert(input, [](auto v){ return ball_to_string(v); });
        if (fn == "string_to_int") return _stdConvert(input, [](auto v) -> BallDyn {
            try { return BallDyn(static_cast<int64_t>(std::stoll(v))); }
            catch (...) { throw BallException("FormatException"s, "FormatException: "s + v); }
        });
        if (fn == "string_to_double") return _stdConvert(input, [](auto v) -> BallDyn {
            try { return BallDyn(std::stod(v)); }
            catch (...) { throw BallException("FormatException"s, "FormatException: "s + v); }
        });
        if (fn == "to_double") {
            auto val = _extractUnaryArg(input);
            return BallDyn(static_cast<double>(_toNum(val)));
        }
        if (fn == "to_int") {
            auto val = _extractUnaryArg(input);
            return BallDyn(_toInt(val));
        }
        if (fn == "string_interpolation") {
            if (ball_is_map(input)) {
                auto parts = BallDyn(input)["parts"s];
                if (ball_is_list(parts)) {
                    std::string result;
                    for (auto p : parts) { result += ball_to_string(p); }
                    return BallDyn(result);
                }
                auto value = BallDyn(input)["value"s];
                if (BallDyn(value).has_value()) return BallDyn(ball_to_string(value));
            }
            return BallDyn(input).has_value() ? BallDyn(ball_to_string(input)) : BallDyn(""s);
        }
        if (fn == "string_substring") return _stdStringSubstring(input);
        if (fn == "string_char_at") return _stdStringCharAt(input);
        if (fn == "string_char_code_at") return _stdStringCharCodeAt(input);
        if (fn == "string_replace") return _stdStringReplace(input, false);
        if (fn == "string_replace_all") return _stdStringReplace(input, true);
        if (fn == "string_repeat") return _stdStringRepeat(input);
        if (fn == "string_pad_left") return _stdStringPad(input, true);
        if (fn == "string_pad_right") return _stdStringPad(input, false);
        if (fn == "string_contains") {
            if (!ball_is_map(input)) return BallDyn(false);
            return BallDyn(BallDyn(input)["value"s].find(static_cast<std::string>(BallDyn(input)["substring"s])) != std::string::npos);
        }
        if (fn == "string_starts_with") {
            if (!ball_is_map(input)) return BallDyn(false);
            std::string s = BallDyn(input)["value"s], p = BallDyn(input)["prefix"s];
            return BallDyn(s.substr(0, p.size()) == p);
        }
        if (fn == "string_ends_with") {
            if (!ball_is_map(input)) return BallDyn(false);
            std::string s = BallDyn(input)["value"s], sx = BallDyn(input)["suffix"s];
            return BallDyn(s.size() >= sx.size() && s.substr(s.size() - sx.size()) == sx);
        }
        if (fn == "string_index_of") {
            if (!ball_is_map(input)) return BallDyn(int64_t(-1));
