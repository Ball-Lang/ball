                ball_set(obj, fieldName, val);
                return val;
            }
        }
        if ((((ball_which_expr(target) == "call"s) && (BallDyn(BallDyn(target)["call"s])["module"s] == "std"s)) && (BallDyn(BallDyn(target)["call"s])["function"s] == "index"s))) {
