        }
        while (true) {
            if (BallDyn(condition).has_value()) {
                auto condVal = _evalExpression(condition, forScope);
                if ((!_toBool(condVal))) {
                    break;
                }
            }
            if (BallDyn(body).has_value()) {
                auto result = _evalExpression(body, forScope);
                if (ball_is_flow_signal(result)) {
                    if ((BallDyn(result)["kind"s] == "return"s)) {
                        return result;
                    }
                    if ((BallDyn(BallDyn(result)["label"s]).has_value() && !BallDyn(result)["label"s].empty())) {
                        return result;
                    }
                    if ((BallDyn(result)["kind"s] == "break"s)) {
