{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    ["./tools/release/only-package-commits.mjs", { "paths": ["cpp"] }],
    ["@semantic-release/changelog", { "changelogFile": "CHANGELOG.md" }],
    ["@semantic-release/exec", {
      "publishCmd": "gh workflow run release-cpp.yml --ref v${nextRelease.version}"
    }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md"],
      "message": "chore(release): ball ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", { "successComment": false }]
  ]
}
