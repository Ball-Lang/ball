                            "messageCreation": {
                              "typeName": "",
                              "fields": [
                                {
                                  "name": "value",
                                  "value": {
                                    "call": {
                                      "module": "std",
                                      "function": "add",
                                      "input": {
                                        "messageCreation": {
                                          "typeName": "BinaryInput",
                                          "fields": [
                                            { "name": "left", "value": { "literal": { "intValue": "2" } } },
                                            {
                                              "name": "right",
                                              "value": {
                                                "call": {
                                                  "module": "std",
                                                  "function": "multiply",
                                                  "input": {
