{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "newLine": "lf",
    "outDir": "dist"
  },
  "include": ["gen/**/*.ts", "gen/**/*.js"]
}
