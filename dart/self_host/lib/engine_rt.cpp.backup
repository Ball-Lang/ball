                        auto catchScope = child(scope);
                        bind(catchScope, variable, exceptionValue);
                        if ((BallDyn(stackVariable).has_value() && !stackVariable.empty())) {
                            bind(catchScope, stackVariable, stackTrace);
                        }
                        auto previousActive = _activeException;
                        (_activeException = exceptionMsg);
                        try {
                            (result = _evalExpression(catchBody, catchScope));
                        } catch (const std::exception& __inner_e) {
                            // Re-throw if catch body throws
                            (_activeException = previousActive);
                            [&](){if (BallDyn(finallyBlock).has_value()) {return BallDyn(_evalExpression(finallyBlock, scope));} return BallDyn();}();
                            throw;
                        }
                        (_activeException = previousActive);
                        (caught = true);
                        break;
                    }
                }
                if ((!caught)) {
                    [&](){if (BallDyn(finallyBlock).has_value()) {return BallDyn(_evalExpression(finallyBlock, scope));} return BallDyn();}();
                    throw BallException(exceptionType, exceptionMsg);
                }
            } else {
                [&](){if (BallDyn(finallyBlock).has_value()) {return BallDyn(_evalExpression(finallyBlock, scope));} return BallDyn();}();
                throw BallException(exceptionType, exceptionMsg);
            }
        }
        [&](){if (BallDyn(finallyBlock).has_value()) {return BallDyn(_evalExpression(finallyBlock, scope));} return BallDyn();}();
        return result;
    }
    BallDyn /* future */ _evalShortCircuitAnd(auto call, BallDyn& scope) {
        auto fields = _lazyFields(call);
        auto left = BallDyn(fields)["left"s];
        auto right = BallDyn(fields)["right"s];
