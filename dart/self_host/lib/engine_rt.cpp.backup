    BallDyn /* future */ _evalLazyForIn(auto call, BallDyn& scope) {
        auto fields = _lazyFields(call);
        auto variable = BallDyn(_stringFieldVal(fields, "variable"s) ? BallDyn(_stringFieldVal(fields, "variable"s)) : BallDyn("item"s));
        auto iterable = BallDyn(fields)["iterable"s];
        auto body = BallDyn(fields)["body"s];
        if ((!BallDyn(iterable).has_value() || !BallDyn(body).has_value())) {
            return BallDyn();
        }
        auto iterVal = _evalExpression(iterable, scope);
        if (!(ball_is_list(iterVal))) {
            // Try to convert to a list for iteration
            if (ball_is_map(iterVal)) {
                // Map iteration: check for key_variable
                auto keyVar = _stringFieldVal(fields, "key_variable"s);
                if (BallDyn(keyVar).has_value() && !keyVar.empty()) {
                    auto valueVar = BallDyn(_stringFieldVal(fields, "value_variable"s) ? BallDyn(_stringFieldVal(fields, "value_variable"s)) : BallDyn("value"s));
                    const BallMap* m = scope_map_cptr(iterVal._val);
                    if (m) {
                        for (auto& [k, v] : *m) {
                            if (k.find("__") == 0 || k == "type_args") continue;
