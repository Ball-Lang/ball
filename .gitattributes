# Auto-detect text files and ensure consistent line endings
* text=auto

# Dart
*.dart text

# C/C++
*.h text
*.cpp text
*.cc text

# TypeScript
*.ts text

# Proto — force LF for cross-platform buf format consistency
*.proto text eol=lf

# Shell scripts — force LF so they run on Unix without \r errors
*.sh text eol=lf

# PowerShell
*.ps1 text

# Web
*.html text
*.css text
*.js text

# Config
*.yaml text
*.yml text
*.json text
*.md text

# Binary
*.png binary
*.jpg binary
*.bin binary
*.pb binary
*.binpb binary
*.snapshot binary
