        }
        for (auto item : iterVal) {
            auto loopScope = child(scope);
            bind(loopScope, variable, item);
            auto result = _evalExpression(body, loopScope);
            if (ball_is_flow_signal(result)) {
                if ((BallDyn(result)["kind"s] == "return"s)) {
                    return result;
                }
                if ((BallDyn(BallDyn(result)["label"s]).has_value() && !BallDyn(result)["label"s].empty())) {
                    return result;
                }
                if ((BallDyn(result)["kind"s] == "break"s)) {
                    break;
                }
            }
        }
        return BallDyn();
    }
    BallDyn /* future */ _evalLazyWhile(auto call, BallDyn& scope) {
