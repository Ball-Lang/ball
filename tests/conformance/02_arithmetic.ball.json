                                                      "typeName": "BinaryInput",
                                                      "fields": [
                                                        { "name": "left", "value": { "literal": { "intValue": "3" } } },
                                                        { "name": "right", "value": { "literal": { "intValue": "4" } } }
                                                      ]
                                                    }
                                                  }
                                                }
                                              }
                                            }
                                          ]
                                        }
                                      }
                                    }
                                  }
                                }
                              ]
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      ],
      "moduleImports": [ { "name": "std" } ]
    }
  ],
