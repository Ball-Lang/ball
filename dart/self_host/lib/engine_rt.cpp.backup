    BallDyn /* future */ _evalIncDec(auto call, BallDyn& scope) {
        auto fields = _lazyFields(call);
        auto valueExpr = BallDyn(fields)["value"s];
        if (!BallDyn(valueExpr).has_value()) {
            return BallDyn();
        }
        std::string fnStr = static_cast<std::string>(BallDyn(call)["function"s]);
        bool isInc = (fnStr.find("increment") != std::string::npos);
        bool isPre = (fnStr.rfind("pre", 0) == 0);
        if ((ball_which_expr(valueExpr) == "reference"s)) {
            auto name = BallDyn(BallDyn(valueExpr)["reference"s])["name"s];
            auto current = lookup(scope, name);
            BallDyn updated;
            if (isInc) updated = current + 1LL;
            else updated = current - 1LL;
            set(scope, name, updated);
            if (isPre) return updated;
            return current;
        }
        if ((ball_which_expr(valueExpr) == "fieldAccess"s)) {
            auto obj = _evalExpression(BallDyn(BallDyn(valueExpr)["fieldAccess"s])["object"s], scope);
            auto fieldName = BallDyn(BallDyn(valueExpr)["fieldAccess"s])["field"s];
            if (ball_is_map(obj)) {
                auto current = BallDyn(obj)[fieldName];
                BallDyn updated;
                if (isInc) updated = current + 1LL;
                else updated = current - 1LL;
                ball_set(obj, fieldName, updated);
                if (isPre) return updated;
                return current;
            }
        }
        auto val = _evalExpression(valueExpr, scope);
        if (isInc) return val + 1LL;
        return val - 1LL;
    }
    BallDyn _applyCompoundOp(auto op, auto current, auto val) {
        std::string opStr = ball_to_string(op);
        if (opStr == "+="s) {
            if (ball_is_string(current) || ball_is_string(val))
                return BallDyn(ball_to_string(current) + ball_to_string(val));
            return _numOp(current, val, [](auto a, auto b){ return a + b; });
        }
        if (opStr == "-="s) return _numOp(current, val, [](auto a, auto b){ return a - b; });
        if (opStr == "*="s) return _numOp(current, val, [](auto a, auto b){ return a * b; });
        if (opStr == "~/="s) return _intOp(current, val, [](auto a, auto b){ return a / b; });
        if (opStr == "%="s) return _intOp(current, val, [](auto a, auto b){ return a % b; });
        if (opStr == "&="s) return _intOp(current, val, [](auto a, auto b){ return a & b; });
        if (opStr == "|="s) return _intOp(current, val, [](auto a, auto b){ return a | b; });
        if (opStr == "^="s) return _intOp(current, val, [](auto a, auto b){ return a ^ b; });
        if (opStr == "<<="s) return _intOp(current, val, [](auto a, auto b){ return a << b; });
        if (opStr == ">>="s) return _intOp(current, val, [](auto a, auto b){ return a >> b; });
        if (opStr == ">>>="s) return _intOp(current, val, [](auto a, auto b){ return a >> b; });
        if (opStr == "??="s) return BallDyn(current).has_value() ? current : val;
        return val;
    }
    BallDyn _numOp(auto a, auto b, auto op) {
        if (ball_is_int(a) && ball_is_int(b))
            return BallDyn(static_cast<int64_t>(op(static_cast<double>(_toInt(a)), static_cast<double>(_toInt(b)))));
        return BallDyn(op(_toNum(a), _toNum(b)));
    }
    BallDyn _intOp(auto a, auto b, auto op) {
        return BallDyn(op(_toInt(a), _toInt(b)));
    }
    BallDyn /* future */ _evalLabeled(auto call, BallDyn& scope) {
        auto fields = _lazyFields(call);
        auto label = _stringFieldVal(fields, "label"s);
        auto body = BallDyn(fields)["body"s];
