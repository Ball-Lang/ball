{
  "name": "@ball-lang/shared",
  "version": "0.1.0",
  "description": "Ball protobuf types for TypeScript — generated by buf from proto/ball/v1/ball.proto. Provides typed message classes with oneof discriminated unions, JSON/binary serialization, and presence checking.",
  "type": "module",
  "main": "gen/ball/v1/ball_pb.js",
  "types": "gen/ball/v1/ball_pb.d.ts",
  "exports": {
    ".": {
      "types": "./gen/ball/v1/ball_pb.d.ts",
      "import": "./gen/ball/v1/ball_pb.js",
      "default": "./gen/ball/v1/ball_pb.js"
    },
    "./proto": {
      "types": "./gen/ball/v1/ball_pb.d.ts",
      "import": "./gen/ball/v1/ball_pb.js",
      "default": "./gen/ball/v1/ball_pb.js"
    }
  },
  "sideEffects": false,
  "keywords": [
    "ball",
    "protobuf",
    "typescript",
    "proto3",
    "code-as-data"
  ],
  "license": "MIT",
  "author": "Ball-Lang <ahmednfwela@bdaya-dev.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ball-Lang/ball.git",
    "directory": "ts/shared"
  },
  "scripts": {
    "test": "node --experimental-strip-types --test test/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "gen/",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0"
  }
}
