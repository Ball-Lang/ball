  "license": "MIT",
  "supports": "!uwp & !android & !ios",
  "dependencies": [
    "nlohmann-json",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ]
}
