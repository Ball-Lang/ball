    bool _typeMatches(auto value, auto type) {
        auto genericMatch = ball_first_match(std::regex("^(\\w+)<(.+)>$"s), type);
        if (BallDyn(genericMatch).has_value()) {
            auto baseType = ball_group(genericMatch, 1LL);
            auto typeArgsStr = ball_group(genericMatch, 2LL);
            auto typeArgs = _splitTypeArgs(typeArgsStr);
            if (((baseType == "List"s) && ball_is_list(value))) {
                if ((static_cast<int64_t>(typeArgs.size()) == 1LL)) {
                    return ball_every(ball_to_list(BallDyn(value)._val), [=](auto e) mutable {
                        return _typeMatches(e, BallDyn(typeArgs)[0LL]);
                    });
                }
                return true;
            }
            if (((baseType == "Map"s) && ball_is_map(value))) {
                if ((static_cast<int64_t>(typeArgs.size()) == 2LL)) {
                    auto entries = BallDyn(value)["entries"s];
                    if (!ball_is_list(entries)) return true;
                    return ball_every(ball_to_list(entries._val), [=](auto e) mutable {
                        return (_typeMatches(BallDyn(e)["key"s], BallDyn(typeArgs)[0LL]) && _typeMatches(BallDyn(e)["value"s], BallDyn(typeArgs)[1LL]));
                    });
                }
                return true;
            }
            if (((baseType == "Set"s) && ball_object_type_matches(value, "Set"s))) {
                if ((static_cast<int64_t>(typeArgs.size()) == 1LL)) {
                    return ball_every(ball_to_list(BallDyn(value)._val), [=](auto e) mutable {
                        return _typeMatches(e, BallDyn(typeArgs)[0LL]);
                    });
                }
                return true;
            }
            if ((ball_is_map(value) && _typeNameMatches(BallDyn(value)["__type__"s], baseType))) {
                auto objArgs = BallDyn(value)["__type_args__"s];
                if ((ball_is_list(objArgs) && (static_cast<int64_t>(objArgs.size()) == static_cast<int64_t>(typeArgs.size())))) {
                    for (auto i = 0; (i < static_cast<int64_t>(typeArgs.size())); (i++)) {
                        if ((BallDyn(objArgs)[i] != BallDyn(typeArgs)[i])) {
                            return false;
                        }
                    }
                    return true;
                }
            }
            return false;
        }
        // Simple type matching
        std::string typeStr = ball_to_string(type);
        if (typeStr == "int") return ball_is_int(value);
        if (typeStr == "double") return ball_is_double(value);
        if (typeStr == "num") return (ball_is_int(value) || ball_is_double(value));
        if (typeStr == "String") return ball_is_string(value);
        if (typeStr == "bool") return ball_is_bool(value);
        if (typeStr == "List") return ball_is_list(value);
        if (typeStr == "Map") return ball_is_map(value);
        if (typeStr == "Set") return ball_object_type_matches(value, "Set");
        if (typeStr == "Null" || typeStr == "void") return !BallDyn(value).has_value();
        if (typeStr == "Object" || typeStr == "dynamic") return true;
        if (typeStr == "Function") return ball_is_function(value);
        return _objectTypeMatches(value, type);
    }
    bool _objectTypeMatches(auto value, auto type) {
        if (!(ball_is_map(value))) {
            return false;
        }
        if (_typeNameMatches(BallDyn(value)["__type__"s], type)) {
            return true;
        }
        auto superObj = BallDyn(value)["__super__"s];
        while (ball_is_map(superObj)) {
            if (_typeNameMatches(BallDyn(superObj)["__type__"s], type)) {
                return true;
            }
            (superObj = BallDyn(superObj)["__super__"s]);
        }
        return false;
    }
    bool _typeNameMatches(auto objType, auto checkType) {
        if (!BallDyn(objType).has_value()) {
            return false;
        }
        if ((objType == checkType)) {
            return true;
        }
        if ([](const std::string& s, const std::string& e){return s.size()>=e.size() && s.compare(s.size()-e.size(),e.size(),e)==0;}(objType, (":"s + ball_to_string(checkType)))) {
            return true;
        }
        if ([](const std::string& s, const std::string& e){return s.size()>=e.size() && s.compare(s.size()-e.size(),e.size(),e)==0;}(checkType, (":"s + ball_to_string(objType)))) {
            return true;
        }
        std::string objStr = ball_to_string(BallDyn(objType)._val);
        std::string checkStr = ball_to_string(BallDyn(checkType)._val);
        auto objColon = static_cast<int64_t>(objStr.find(":"));
        auto checkColon = static_cast<int64_t>(checkStr.find(":"));
        if (objColon == static_cast<int64_t>(std::string::npos)) objColon = -1;
        if (checkColon == static_cast<int64_t>(std::string::npos)) checkColon = -1;
        if (((objColon >= 0LL) && (checkColon >= 0LL))) {
            return (objStr.substr(objColon + 1) == checkStr.substr(checkColon + 1));
        }
        return false;
    }
    std::vector<std::any> _splitTypeArgs(auto str) {
        auto args = std::vector<std::any>{};
        auto depth = 0LL;
        auto start = 0LL;
        for (auto i = 0; (i < static_cast<int64_t>(str.size())); (i++)) {
            if ((BallDyn(str)[i] == "<"s)) {
                (depth++);
            }
            if ((BallDyn(str)[i] == ">"s)) {
                (depth--);
            }
            if (((BallDyn(str)[i] == ","s) && (depth == 0LL))) {
                args.push_back([](const std::string& s){auto a=s.find_first_not_of(" \t\n\r"),b=s.find_last_not_of(" \t\n\r");return a==std::string::npos?std::string():s.substr(a,b-a+1);}(str.substr(start, i - start)));
                (start = (i + 1LL));
            }
        }
        args.push_back([](const std::string& s){auto a=s.find_first_not_of(" \t\n\r"),b=s.find_last_not_of(" \t\n\r");return a==std::string::npos?std::string():s.substr(a,b-a+1);}(str.substr(start)));
        return args;
    }
    BallDyn _stdMapCreate(auto input) {
        if (!(ball_is_map(input))) {
            return std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}};
        }
        auto entries = BallDyn(input)["entries"s];
        if (ball_is_list(entries)) {
            auto result = std::map<std::string,std::any>{{"type_args", std::any("Object?, Object?"s)}};
            for (auto entry : entries) {
                if (ball_is_map(entry)) {
                    ball_set(result, BallDyn(entry)["name"s], BallDyn(entry)["value"s]);
                }
            }
            return result;
        }
        return std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}};
    }
    BallDyn _stdSetCreate(auto input) {
        if (!(ball_is_map(input))) {
