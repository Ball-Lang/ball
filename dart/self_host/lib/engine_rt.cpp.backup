}

inline std::string ball_which_source(const std::any& obj) {
    if (!obj.has_value()) return "notSet";
    if (obj.type() == typeid(std::map<std::string, std::any>)) {
        auto& m = std::any_cast<const std::map<std::string, std::any>&>(obj);
        if (m.count("httpSource") && m.at("httpSource").has_value()) return "httpSource";
        if (m.count("fileSource") && m.at("fileSource").has_value()) return "fileSource";
        if (m.count("inlineSource") && m.at("inlineSource").has_value()) return "inlineSource";
        if (m.count("gitSource") && m.at("gitSource").has_value()) return "gitSource";
    }
    if (obj.type() == typeid(std::unordered_map<std::string, std::any>)) {
        auto& m = std::any_cast<const std::unordered_map<std::string, std::any>&>(obj);
        if (m.count("httpSource") && m.at("httpSource").has_value()) return "httpSource";
        if (m.count("fileSource") && m.at("fileSource").has_value()) return "fileSource";
        if (m.count("inlineSource") && m.at("inlineSource").has_value()) return "inlineSource";
        if (m.count("gitSource") && m.at("gitSource").has_value()) return "gitSource";
    }
    return "notSet";
}

inline std::string ball_which_stmt(const std::any& obj) {
    if (!obj.has_value()) return "notSet";
    if (obj.type() == typeid(std::map<std::string, std::any>)) {
        auto& m = std::any_cast<const std::map<std::string, std::any>&>(obj);
        if (m.count("let") && m.at("let").has_value()) return "let";
        if (m.count("expression") && m.at("expression").has_value()) return "expression";
    }
    if (obj.type() == typeid(std::unordered_map<std::string, std::any>)) {
        auto& m = std::any_cast<const std::unordered_map<std::string, std::any>&>(obj);
        if (m.count("let") && m.at("let").has_value()) return "let";
        if (m.count("expression") && m.at("expression").has_value()) return "expression";
    }
    return "notSet";
}

// ── Collection helpers ──

// Convert any iterable-like value to a std::vector<std::any>.
template<typename T>
inline std::vector<std::any> ball_to_list(const std::vector<T>& v) {
    std::vector<std::any> result;
    result.reserve(v.size());
    for (const auto& el : v) result.push_back(std::any(el));
    return result;
}
inline std::vector<std::any> ball_to_list(const std::any& v) {
    if (v.type() == typeid(std::vector<std::any>))
        return std::any_cast<std::vector<std::any>>(v);
    if (v.type() == typeid(std::vector<std::string>)) {
        auto& sv = std::any_cast<const std::vector<std::string>&>(v);
        std::vector<std::any> r;
        for (auto& s : sv) r.push_back(std::any(s));
        return r;
    }
    return {};
}

// Remove duplicates (set-like).
template<typename T>
inline std::vector<T> ball_to_set(const std::vector<T>& v) {
    std::vector<T> result;
    for (const auto& el : v) {
        bool found = false;
        for (const auto& r : result) {
            // Simple equality for common types
            if constexpr (std::is_same_v<T, std::any>) {
                // For std::any, compare by string representation
                if (ball_to_string(el) == ball_to_string(r)) { found = true; break; }
            } else {
                if (el == r) { found = true; break; }
            }
        }
        if (!found) result.push_back(el);
    }
    return result;
}

// Filter elements.
template<typename T, typename F>
inline std::vector<T> ball_where(const std::vector<T>& v, F pred) {
    std::vector<T> result;
    for (const auto& el : v) {
        if (pred(el)) result.push_back(el);
    }
    return result;
}

// Transform elements.
template<typename T, typename F>
inline auto ball_map(const std::vector<T>& v, F fn) {
    using R = decltype(fn(std::declval<T>()));
    std::vector<R> result;
    result.reserve(v.size());
    for (const auto& el : v) result.push_back(fn(el));
    return result;
}

// Check if all elements satisfy a predicate.
template<typename T, typename F>
inline bool ball_every(const std::vector<T>& v, F pred) {
    for (const auto& el : v) {
        if (!pred(el)) return false;
    }
    return true;
}

// Append all elements from src to dst.
template<typename T>
inline void ball_add_all(std::vector<T>& dst, const std::vector<T>& src) {
    dst.insert(dst.end(), src.begin(), src.end());
}
// Overload for maps.
template<typename K, typename V>
inline void ball_add_all(std::map<K, V>& dst, const std::map<K, V>& src) {
    for (const auto& [k, v] : src) dst[k] = v;
}
template<typename K, typename V>
inline void ball_add_all(std::unordered_map<K, V>& dst, const std::unordered_map<K, V>& src) {
    for (const auto& [k, v] : src) dst[k] = v;
}

// Put a value in a map only if the key is absent.
template<typename M, typename K, typename F>
inline void ball_put_if_absent(M& m, const K& key, F factory) {
    if (m.count(key) == 0) m[key] = factory();
}

// Take first N elements.
template<typename T>
inline std::vector<T> ball_take(const std::vector<T>& v, int64_t n) {
    auto end = std::min(static_cast<size_t>(n), v.size());
    return std::vector<T>(v.begin(), v.begin() + end);
}

// Skip first N elements.
template<typename T>
inline std::vector<T> ball_skip(const std::vector<T>& v, int64_t n) {
    auto start = std::min(static_cast<size_t>(n), v.size());
    return std::vector<T>(v.begin() + start, v.end());
}

// Build a map from a list of key-value pairs.
inline std::map<std::string, std::any> ball_from_entries(const std::vector<std::any>& entries) {
    std::map<std::string, std::any> result;
    for (const auto& e : entries) {
        if (e.type() == typeid(std::map<std::string, std::any>)) {
            auto& m = std::any_cast<const std::map<std::string, std::any>&>(e);
            auto kit = m.find("key");
            auto vit = m.find("value");
            if (kit != m.end() && vit != m.end()) {
                result[std::any_cast<std::string>(kit->second)] = vit->second;
            }
        }
    }
    return result;
}

// ── Regex helpers ──

// Find first regex match — returns a std::any wrapping match data or empty.
inline std::any ball_first_match(const std::regex& re, const std::string& s) {
    std::smatch m;
    if (std::regex_search(s, m, re)) {
        std::vector<std::any> groups;
        for (size_t i = 0; i < m.size(); ++i) {
            groups.push_back(std::any(m[i].str()));
        }
        return std::any(groups);
    }
    return std::any{};
}

// Extract a capture group from a match result.
inline std::string ball_group(const std::any& match, int64_t idx) {
    if (!match.has_value()) return "";
    if (match.type() == typeid(std::vector<std::any>)) {
        auto& groups = std::any_cast<const std::vector<std::any>&>(match);
        if (idx >= 0 && static_cast<size_t>(idx) < groups.size()) {
            return std::any_cast<std::string>(groups[idx]);
        }
    }
    return "";
}

// Find all regex matches — returns a vector of match data.
inline std::vector<std::any> ball_all_matches(const std::regex& re, const std::string& s) {
    std::vector<std::any> results;
    auto it = std::sregex_iterator(s.begin(), s.end(), re);
    for (; it != std::sregex_iterator(); ++it) {
        std::vector<std::any> groups;
        for (size_t i = 0; i < it->size(); ++i) {
            groups.push_back(std::any((*it)[i].str()));
        }
        results.push_back(std::any(groups));
    }
    return results;
}

// ── Dart tryParse ──
// tryParse(type, str) — attempt to parse a string as int or double.
// Returns the parsed value on success, or std::any{} on failure.
inline std::any ball_try_parse(const std::any& type_tag, const std::string& s) {
    std::string tag;
    if (type_tag.type() == typeid(std::string))
        tag = std::any_cast<std::string>(type_tag);
    else
        tag = ball_to_string(type_tag);
    if (tag == "int" || tag == "int_") {
        try { return std::any(static_cast<int64_t>(std::stoll(s))); }
        catch (...) { return std::any{}; }
    }
    if (tag == "double" || tag == "double_" || tag == "num") {
        try { return std::any(std::stod(s)); }
        catch (...) { return std::any{}; }
    }
    return std::any{};
}

// ── Generic field-set helper ──
// Works for both BallDyn (uses .set()) and std::map<std::string, std::any>
// (uses operator[]=).
class BallDyn;  // forward
template<typename T>
inline void ball_set(T& obj, const std::string& key, const std::any& value) {
    obj[key] = value;
}
// BallDyn specialization uses the .set() method
// (defined after BallDyn class definition, see ball_dyn.h)
template<typename T>
inline void ball_set(T& obj, int64_t idx, const std::any& value) {
    obj[idx] = value;
}

// ── BallDyn overload for ball_to_string ──
// (forward declared; BallDyn must be defined before this is used)
// Placed here so it's available in both engine and compiled programs.
class BallDyn;
inline std::string ball_to_string(const BallDyn& d);
// Implemented after BallDyn is defined — see ball_dyn.h or the
// generated preamble where both headers are spliced in sequence.

// ================================================================
// Self-hosted engine compatibility stubs
// ================================================================
//
// The self-hosted Ball engine (compiled from Dart → Ball → C++)
// references Dart-specific types and functions that don't exist in
// C++. These stubs provide minimal implementations so the generated
// code compiles. They are only used by the self-hosted engine, not
// by normal compiled Ball programs.

// ── JSON encode/decode stubs ──
// Dart's `JsonEncoder` / `JsonDecoder` classes with a `convert()`
// method. In compiled C++ we stub them to do basic
// ball_to_string / passthrough.
struct JsonEncoder {
    bool __const__ = false;
};
struct JsonDecoder {
    bool __const__ = false;
};
inline std::string convert(const JsonEncoder&, const std::any& value) {
    return ball_to_string(value);
}
inline std::any convert(const JsonDecoder&, const std::string& text) {
    // Minimal JSON decode: try to parse as number, bool, null, or return as string.
    if (text == "null") return std::any{};
    if (text == "true") return std::any(true);
    if (text == "false") return std::any(false);
    try { return std::any(static_cast<int64_t>(std::stoll(text))); } catch (...) {}
    try { return std::any(std::stod(text)); } catch (...) {}
    // Strip surrounding quotes if present
    if (text.size() >= 2 && text.front() == '"' && text.back() == '"')
        return std::any(text.substr(1, text.size() - 2));
    return std::any(text);
}

// ── utf8 / base64 codec stubs ──
// Dart uses `utf8.encode(s)` / `utf8.decode(bytes)` and
// `base64.encode(bytes)` / `base64.decode(s)`.
struct Utf8Codec {
    std::vector<std::any> encode(const std::string& s) const {
        std::vector<std::any> result;
        for (unsigned char c : s) result.push_back(std::any(static_cast<int64_t>(c)));
        return result;
    }
    std::string decode(const std::vector<std::any>& bytes) const {
        std::string result;
        for (const auto& b : bytes) {
            if (b.type() == typeid(int64_t))
                result += static_cast<char>(std::any_cast<int64_t>(b));
        }
        return result;
    }
};
inline std::vector<std::any> encode(const Utf8Codec& c, const std::string& s) { return c.encode(s); }
inline std::string decode(const Utf8Codec& c, const std::vector<std::any>& b) { return c.decode(b); }

struct Base64Codec {
    std::string encode(const std::vector<std::any>& bytes) const {
        static const char* alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
        std::vector<uint8_t> raw;
        for (const auto& b : bytes) {
            if (b.type() == typeid(int64_t)) raw.push_back(static_cast<uint8_t>(std::any_cast<int64_t>(b)));
        }
        std::string o;
        size_t i = 0;
        for (; i + 3 <= raw.size(); i += 3) {
            o += alphabet[(raw[i] >> 2) & 0x3f];
            o += alphabet[((raw[i] & 0x3) << 4) | ((raw[i+1] >> 4) & 0xf)];
            o += alphabet[((raw[i+1] & 0xf) << 2) | ((raw[i+2] >> 6) & 0x3)];
            o += alphabet[raw[i+2] & 0x3f];
        }
        if (i < raw.size()) {
            o += alphabet[(raw[i] >> 2) & 0x3f];
            if (i + 1 == raw.size()) {
                o += alphabet[(raw[i] & 0x3) << 4]; o += "==";
            } else {
                o += alphabet[((raw[i] & 0x3) << 4) | ((raw[i+1] >> 4) & 0xf)];
                o += alphabet[(raw[i+1] & 0xf) << 2]; o += '=';
            }
        }
        return o;
    }
    std::vector<std::any> decode(const std::string& s) const {
        static int tbl[256] = {};
        static bool inited = false;
        if (!inited) {
            for (int j = 0; j < 256; j++) tbl[j] = -1;
            const char* a = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";
            for (int j = 0; j < 64; j++) tbl[(unsigned char)a[j]] = j;
            inited = true;
        }
        std::vector<std::any> o;
        int v = 0, bits = 0;
        for (char c : s) {
            if (c == '=' || c == '\n' || c == '\r' || c == ' ' || c == '\t') continue;
            int d = tbl[(unsigned char)c]; if (d < 0) continue;
            v = (v << 6) | d; bits += 6;
            if (bits >= 8) { bits -= 8; o.push_back(std::any(static_cast<int64_t>((v >> bits) & 0xff))); }
        }
        return o;
    }
};
inline std::string encode(const Base64Codec& c, const std::vector<std::any>& b) { return c.encode(b); }
inline std::vector<std::any> decode(const Base64Codec& c, const std::string& s) { return c.decode(s); }

// Global instances matching Dart's top-level `utf8` and `base64`.
inline Utf8Codec utf8;
inline Base64Codec base64;

// ── Function type stub ──
// Dart code references `Function` as a type. In C++ it doesn't exist
// as a standalone identifier. `apply(Function, callee, args)` in the
// self-hosted engine wraps a dynamic function call.
struct FunctionType {};
inline FunctionType Function;
inline std::any apply(const FunctionType&, const std::any& callee, const std::vector<std::any>& args) {
    // Attempt to call the callee as a BallFunc with the first argument (or null).
    if (callee.type() == typeid(std::function<std::any(std::any)>)) {
        auto& fn = std::any_cast<const std::function<std::any(std::any)>&>(callee);
        return fn(args.empty() ? std::any{} : args[0]);
    }
    return std::any{};
}

// ── Map.from stub ──
// Dart `Map.from(otherMap)` creates a copy. The encoder emits it as
// `Map_from{.__type_args__=..., .arg0=input}` — a struct constructor.
// We provide a minimal struct that extracts the map from the input.
struct Map_from {
    std::string __type_args__;
    std::any arg0;

    // Forward map-like operations to the underlying value
    int64_t size() const {
        if (arg0.type() == typeid(std::map<std::string, std::any>))
            return std::any_cast<const std::map<std::string, std::any>&>(arg0).size();
        if (arg0.type() == typeid(std::unordered_map<std::string, std::any>))
            return std::any_cast<const std::unordered_map<std::string, std::any>&>(arg0).size();
        return 0;
    }
    bool empty() const { return size() == 0; }
    std::any operator[](const std::string& key) const {
        if (arg0.type() == typeid(std::map<std::string, std::any>)) {
            auto& m = std::any_cast<const std::map<std::string, std::any>&>(arg0);
            auto it = m.find(key); return it != m.end() ? it->second : std::any{};
        }
        if (arg0.type() == typeid(std::unordered_map<std::string, std::any>)) {
            auto& m = std::any_cast<const std::unordered_map<std::string, std::any>&>(arg0);
            auto it = m.find(key); return it != m.end() ? it->second : std::any{};
        }
        return std::any{};
    }
};

// ── io.FileMode stub ──
// Dart's `FileMode.append` etc. The self-hosted engine references
// `io_FileMode["append"]`. Provide as a map.
inline std::map<std::string, std::any> io_FileMode = {
    {"append", std::any(std::string("append"))},
    {"write", std::any(std::string("write"))},
    {"read", std::any(std::string("read"))},
};

// ── File I/O stubs ──
// The self-hosted engine calls `File(path)`, `readAsStringSync(file)`,
// `writeAsStringSync(file, content)`, etc. Provide stubs.
struct File {
    std::string path;
    File(const std::string& p) : path(p) {}
    File(const std::any& p) : path(ball_to_string(p)) {}
};
inline std::string readAsStringSync(const File& f) {
    std::ifstream ifs(f.path);
    return std::string((std::istreambuf_iterator<char>(ifs)),
                        std::istreambuf_iterator<char>());
}
inline void writeAsStringSync(const File& f, const std::string& content, const std::any& = {}) {
    std::ofstream ofs(f.path);
    ofs << content;
}
inline void writeAsStringSync(const File& f, const std::any& content, const std::any& = {}) {
    std::ofstream ofs(f.path);
    ofs << ball_to_string(content);
}
inline void writeAsBytesSync(const File& f, const std::any&) {
    // Stub — byte write not fully implemented
}
inline bool existsSync(const File& f) {
    std::ifstream ifs(f.path);
    return ifs.good();
}
inline void deleteSync(const File& f) {
    std::remove(f.path.c_str());
}

// ── Scope/bind/child stubs ──
// The self-hosted engine uses `child(scope)`, `bind(scope, name, value)`,
// `resolve(scope, name)` for scope chain management. These are methods
// on the BallEngine class, but sometimes the compiler emits them as
// free function calls. We provide free-function overloads.
inline std::any child(const std::any& scope) {
    // Create a new scope with the parent set
    std::map<std::string, std::any> newScope;
    newScope["__parent__"] = scope;
    return std::any(newScope);
}
inline void bind(std::any& scope, const std::any& name, const std::any& value) {
    if (scope.type() == typeid(std::map<std::string, std::any>)) {
        std::any_cast<std::map<std::string, std::any>&>(scope)[ball_to_string(name)] = value;
    }
}
// Forward declaration; BallDyn defined later
class BallDyn;
// Overloads for BallDyn arguments — defined after BallDyn class
inline std::any resolve(const std::any& scope, const std::string& name) {
    if (scope.type() == typeid(std::map<std::string, std::any>)) {
        auto& m = std::any_cast<const std::map<std::string, std::any>&>(scope);
        auto it = m.find(name);
        if (it != m.end()) return it->second;
        auto pit = m.find("__parent__");
        if (pit != m.end()) return resolve(pit->second, name);
    }
    return std::any{};
}
// Overload for BallDyn resolver + import
inline std::any resolve(const std::any&, const std::any&) {
    return std::any{};  // Stub: lazy module resolution not supported in compiled mode
}

// ── Scope exit stubs ──
// The Ball IR for _runScopeExits has a bug where it references `expr` and
// `evalScope` which are not defined. Declare dummies so the code compiles.
// The actual scope exit evaluation won't work correctly but the engine
// will compile without errors.
inline std::any expr;
inline std::any evalScope;

// ── has_value / empty free functions ──
// Some generated code calls .has_value() or .empty() on std::string,
// which doesn't have has_value(). Provide free-function overloads.
// (These are found by ADL only if needed)

// ── toUtc stub ──
// Dart's DateTime.now().toUtc() — returns the same map (already UTC in C++)
inline std::map<std::string, std::any> toUtc(const std::map<std::string, std::any>& dt) {
    return dt;
}
inline std::any toUtc(const std::any& dt) {
    if (dt.type() == typeid(std::map<std::string, std::any>))
        return dt;
    return std::any{};
}

// ── Object type stub ──
// Dart uses `Object` as a base type. Emit as a string.
inline std::string Object = "Object";

// ── Math function aliases ──
// The sanitize_name function appends _ to stdlib collision names,
// so user code references sqrt_, pow_, etc. These wrap the real functions.
inline double sqrt_(double v) { return std::sqrt(v); }
inline double pow_(double a, double b) { return std::pow(a, b); }
inline double log_(double v) { return std::log(v); }
inline double exp_(double v) { return std::exp(v); }
inline double sin_(double v) { return std::sin(v); }
inline double cos_(double v) { return std::cos(v); }
inline double tan_(double v) { return std::tan(v); }
inline double atan_(double v) { return std::atan(v); }
inline double atan2_(double a, double b) { return std::atan2(a, b); }
// BallDyn overloads for math
inline double sqrt_(const std::any& v) { return std::sqrt(v.type() == typeid(double) ? std::any_cast<double>(v) : static_cast<double>(std::any_cast<int64_t>(v))); }
inline double pow_(const std::any& a, const std::any& b) {
    double da = a.type() == typeid(double) ? std::any_cast<double>(a) : static_cast<double>(std::any_cast<int64_t>(a));
    double db = b.type() == typeid(double) ? std::any_cast<double>(b) : static_cast<double>(std::any_cast<int64_t>(b));
    return std::pow(da, db);
}
inline double log_(const std::any& v) { return log_(v.type() == typeid(double) ? std::any_cast<double>(v) : static_cast<double>(std::any_cast<int64_t>(v))); }
inline double exp_(const std::any& v) { return exp_(v.type() == typeid(double) ? std::any_cast<double>(v) : static_cast<double>(std::any_cast<int64_t>(v))); }
inline double sin_(const std::any& v) { return sin_(v.type() == typeid(double) ? std::any_cast<double>(v) : static_cast<double>(std::any_cast<int64_t>(v))); }
inline double cos_(const std::any& v) { return cos_(v.type() == typeid(double) ? std::any_cast<double>(v) : static_cast<double>(std::any_cast<int64_t>(v))); }
inline double tan_(const std::any& v) { return tan_(v.type() == typeid(double) ? std::any_cast<double>(v) : static_cast<double>(std::any_cast<int64_t>(v))); }
inline double atan_(const std::any& v) { return atan_(v.type() == typeid(double) ? std::any_cast<double>(v) : static_cast<double>(std::any_cast<int64_t>(v))); }
inline double atan2_(const std::any& a, const std::any& b) {
    double da = a.type() == typeid(double) ? std::any_cast<double>(a) : static_cast<double>(std::any_cast<int64_t>(a));
    double db = b.type() == typeid(double) ? std::any_cast<double>(b) : static_cast<double>(std::any_cast<int64_t>(b));
    return std::atan2(da, db);
}

// ── handles/call stubs for module handlers ──
inline bool handles(const std::any&, const std::any&) { return false; }
inline std::any call(const std::any&, const std::any&, const std::any&, const std::any&) { return std::any{}; }

// ── Dart async/time/math stubs ──
// Future.delayed — just sleep synchronously
struct DurationType { int64_t milliseconds = 0; };
using Duration = DurationType;
struct FutureType {};
inline FutureType Future;
inline std::any delayed(const FutureType&, const DurationType& d) {
    std::this_thread::sleep_for(std::chrono::milliseconds(d.milliseconds));
    return std::any{};
}

// DateTime.now() — returns a map with millisecondsSinceEpoch
struct DateTimeType {};
inline DateTimeType DateTime;
inline std::map<std::string, std::any> now(const DateTimeType&) {
    auto ms = std::chrono::duration_cast<std::chrono::milliseconds>(
        std::chrono::system_clock::now().time_since_epoch()).count();
    return {{"millisecondsSinceEpoch", std::any(static_cast<int64_t>(ms))}};
}

// Random — simple wrappers around C++ random
struct RandomType {
    mutable std::mt19937_64 gen{std::random_device{}()};
};
inline int64_t nextInt(const RandomType& r, int64_t max_) {
    return std::uniform_int_distribution<int64_t>(0, max_ - 1)(r.gen);
}
// Overload for BallDyn max
inline int64_t nextInt(const RandomType& r, const std::any& max_val) {
    int64_t mx = 100;
    if (max_val.type() == typeid(int64_t)) mx = std::any_cast<int64_t>(max_val);
    return nextInt(r, mx);
}
inline double nextDouble(const RandomType& r) {
    return std::uniform_real_distribution<double>(0.0, 1.0)(r.gen);
}

// stderr_ — print to stderr (name collision avoidance with C macro)
inline void stderr_(const std::string& msg) {
    std::cerr << msg << std::endl;
}
inline void stderr_(const std::any& msg) {
    std::cerr << ball_to_string(msg) << std::endl;
}

// _envGet stub — wraps std::getenv
inline std::string _envGet(const std::string& name) {
    auto v = std::getenv(name.c_str());
    return v ? std::string(v) : std::string();
}
inline std::string _envGet(const std::any& name) {
    return _envGet(ball_to_string(name));
}

#endif  // BALL_EMIT_RUNTIME_H

// ball_dyn.h -- Dynamic value type for Ball compiled programs.
//
// BallDyn is a JavaScript-like dynamic value type that wraps std::any and
// provides operator overloading for field access, arithmetic, comparison,
// string operations, and iteration. It enables compiled Ball programs that
// use dynamic typing (e.g., the self-hosted Ball engine) to work in C++.
//
// Usage: BallDyn values can hold any type (int64_t, double, std::string,
// bool, vectors, maps, functions, etc.) and support transparent access.

#ifndef BALL_DYN_H
#define BALL_DYN_H

#include <any>
#include <cstdint>
#include <functional>
#include <iostream>
#include <map>
#include <string>
#include <unordered_map>
#include <vector>

using BallMap = std::map<std::string, std::any>;
using BallUMap = std::unordered_map<std::string, std::any>;
using BallList = std::vector<std::any>;
using BallFunc = std::function<std::any(std::any)>;

class BallDyn {
public:
    std::any _val;

    // Constructors
    BallDyn() : _val() {}
    BallDyn(std::any v) : _val(std::move(v)) {}
    BallDyn(int64_t v) : _val(v) {}
    BallDyn(int v) : _val(static_cast<int64_t>(v)) {}
    BallDyn(double v) : _val(v) {}
    BallDyn(bool v) : _val(v) {}
    BallDyn(const std::string& v) : _val(v) {}
    BallDyn(std::string&& v) : _val(std::move(v)) {}
    BallDyn(const char* v) : _val(std::string(v)) {}
    BallDyn(BallMap v) : _val(std::move(v)) {}
    BallDyn(BallUMap v) : _val(std::move(v)) {}
    BallDyn(BallList v) : _val(std::move(v)) {}
    BallDyn(BallFunc v) : _val(std::move(v)) {}

    // Copy/move
    BallDyn(const BallDyn& o) : _val(o._val) {}
    BallDyn(BallDyn&& o) noexcept : _val(std::move(o._val)) {}
    BallDyn& operator=(const BallDyn& o) { _val = o._val; return *this; }
    BallDyn& operator=(BallDyn&& o) noexcept { _val = std::move(o._val); return *this; }

    // Assign from common types
    BallDyn& operator=(int64_t v) { _val = v; return *this; }
    BallDyn& operator=(int v) { _val = static_cast<int64_t>(v); return *this; }
    BallDyn& operator=(double v) { _val = v; return *this; }
    BallDyn& operator=(bool v) { _val = v; return *this; }
    BallDyn& operator=(const std::string& v) { _val = v; return *this; }
    BallDyn& operator=(const char* v) { _val = std::string(v); return *this; }

    // Implicit conversion to std::any
    operator std::any() const { return _val; }

    // Truthiness (like JavaScript)
    bool has_value() const { return _val.has_value(); }
    explicit operator bool() const {
        if (!_val.has_value()) return false;
        if (_val.type() == typeid(bool)) return std::any_cast<bool>(_val);
        if (_val.type() == typeid(int64_t)) return std::any_cast<int64_t>(_val) != 0;
        if (_val.type() == typeid(int)) return std::any_cast<int>(_val) != 0;
        if (_val.type() == typeid(double)) return std::any_cast<double>(_val) != 0.0;
        if (_val.type() == typeid(std::string)) return !std::any_cast<const std::string&>(_val).empty();
        return true;  // non-null = truthy
    }

    // Type queries
    const std::type_info& type() const { return _val.type(); }

    // String conversion
    operator std::string() const {
        if (!_val.has_value()) return "null";
        if (_val.type() == typeid(std::string)) return std::any_cast<std::string>(_val);
        if (_val.type() == typeid(const char*)) return std::any_cast<const char*>(_val);
        if (_val.type() == typeid(int64_t)) return std::to_string(std::any_cast<int64_t>(_val));
        if (_val.type() == typeid(int)) return std::to_string(std::any_cast<int>(_val));
        if (_val.type() == typeid(double)) {
            double d = std::any_cast<double>(_val);
            if (d == static_cast<double>(static_cast<long long>(d)))
                return std::to_string(static_cast<long long>(d)) + ".0";
            return std::to_string(d);
        }
        if (_val.type() == typeid(bool)) return std::any_cast<bool>(_val) ? "true" : "false";
        return "<dynamic>";
    }

    // Numeric conversion
    operator int64_t() const {
        if (_val.type() == typeid(int64_t)) return std::any_cast<int64_t>(_val);
        if (_val.type() == typeid(int)) return std::any_cast<int>(_val);
        if (_val.type() == typeid(double)) return static_cast<int64_t>(std::any_cast<double>(_val));
        if (_val.type() == typeid(bool)) return std::any_cast<bool>(_val) ? 1 : 0;
        return 0;
    }
    operator double() const {
        if (_val.type() == typeid(double)) return std::any_cast<double>(_val);
        if (_val.type() == typeid(int64_t)) return static_cast<double>(std::any_cast<int64_t>(_val));
        if (_val.type() == typeid(int)) return static_cast<double>(std::any_cast<int>(_val));
        return 0.0;
    }

    // Field/index access via operator[]
    // Returns a copy of the field value. For mutation, use the set() method.
    BallDyn operator[](const std::string& key) const {
        if (_val.type() == typeid(BallMap)) {
            auto& m = const_cast<BallMap&>(std::any_cast<const BallMap&>(_val));
            return BallDyn(m[key]);
        }
        if (_val.type() == typeid(BallUMap)) {
            auto& m = const_cast<BallUMap&>(std::any_cast<const BallUMap&>(_val));
            return BallDyn(m[key]);
        }
        if (_val.type() == typeid(std::shared_ptr<BallMap>)) {
            auto& ptr = std::any_cast<const std::shared_ptr<BallMap>&>(_val);
            if (ptr) return BallDyn((*ptr)[key]);
        }
        return BallDyn();
    }

    // Index access for vectors
    BallDyn operator[](int64_t idx) const {
        if (_val.type() == typeid(BallList)) {
            auto& v = std::any_cast<const BallList&>(_val);
            if (idx >= 0 && static_cast<size_t>(idx) < v.size())
                return BallDyn(v[idx]);
        }
        if (_val.type() == typeid(std::vector<std::string>)) {
            auto& v = std::any_cast<const std::vector<std::string>&>(_val);
            if (idx >= 0 && static_cast<size_t>(idx) < v.size())
                return BallDyn(std::any(v[idx]));
        }
        return BallDyn();
    }

    // Mutation: set a field in the underlying map/list.
    // `obj.set("key", value)` modifies the map entry in-place.
    void set(const std::string& key, const std::any& value) {
        if (_val.type() == typeid(BallMap)) {
            std::any_cast<BallMap&>(_val)[key] = value;
        } else if (_val.type() == typeid(BallUMap)) {
            std::any_cast<BallUMap&>(_val)[key] = value;
        } else if (_val.type() == typeid(std::shared_ptr<BallMap>)) {
            auto& ptr = std::any_cast<std::shared_ptr<BallMap>&>(_val);
            if (ptr) (*ptr)[key] = value;
        }
    }
    void set(const std::string& key, const BallDyn& value) {
        set(key, value._val);
    }
    void set(int64_t idx, const std::any& value) {
        if (_val.type() == typeid(BallList)) {
            auto& v = std::any_cast<BallList&>(_val);
            if (idx >= 0 && static_cast<size_t>(idx) < v.size())
                v[idx] = value;
        }
    }

    // BallDyn-keyed access: convert key to string and delegate
    BallDyn operator[](const BallDyn& key) const {
        return (*this)[static_cast<std::string>(key)];
    }
    void set(const BallDyn& key, const BallDyn& value) {
        set(static_cast<std::string>(key), value._val);
    }

    // Map operations
    size_t count(const std::string& key) const {
        if (_val.type() == typeid(BallMap))
            return std::any_cast<const BallMap&>(_val).count(key);
        if (_val.type() == typeid(BallUMap))
            return std::any_cast<const BallUMap&>(_val).count(key);
        if (_val.type() == typeid(std::shared_ptr<BallMap>)) {
            auto& ptr = std::any_cast<const std::shared_ptr<BallMap>&>(_val);
            return ptr ? ptr->count(key) : 0;
        }
        return 0;
    }

    // Collection operations
    bool empty() const {
        if (!_val.has_value()) return true;
        if (_val.type() == typeid(std::string)) return std::any_cast<const std::string&>(_val).empty();
        if (_val.type() == typeid(BallList)) return std::any_cast<const BallList&>(_val).empty();
        if (_val.type() == typeid(BallMap)) return std::any_cast<const BallMap&>(_val).empty();
        if (_val.type() == typeid(BallUMap)) return std::any_cast<const BallUMap&>(_val).empty();
        if (_val.type() == typeid(std::shared_ptr<BallMap>)) {
            auto& ptr = std::any_cast<const std::shared_ptr<BallMap>&>(_val);
            return !ptr || ptr->empty();
        }
        return false;
    }

    int64_t size() const {
        if (_val.type() == typeid(std::string)) return std::any_cast<const std::string&>(_val).size();
        if (_val.type() == typeid(BallList)) return std::any_cast<const BallList&>(_val).size();
        if (_val.type() == typeid(BallMap)) return std::any_cast<const BallMap&>(_val).size();
        if (_val.type() == typeid(BallUMap)) return std::any_cast<const BallUMap&>(_val).size();
        if (_val.type() == typeid(std::shared_ptr<BallMap>)) {
            auto& ptr = std::any_cast<const std::shared_ptr<BallMap>&>(_val);
            return ptr ? static_cast<int64_t>(ptr->size()) : 0;
        }
        return 0;
    }

    void push_back(const BallDyn& v) {
        if (_val.type() == typeid(BallList)) {
            std::any_cast<BallList&>(_val).push_back(v._val);
        }
    }

    BallDyn front() const {
        if (_val.type() == typeid(BallList)) {
            auto& l = std::any_cast<const BallList&>(_val);
            return l.empty() ? BallDyn() : BallDyn(l.front());
        }
        return BallDyn();
    }

    BallDyn back() const {
        if (_val.type() == typeid(BallList)) {
            auto& l = std::any_cast<const BallList&>(_val);
            return l.empty() ? BallDyn() : BallDyn(l.back());
        }
        return BallDyn();
    }

    void erase(const std::string& key) {
        if (_val.type() == typeid(BallMap))
            std::any_cast<BallMap&>(_val).erase(key);
        if (_val.type() == typeid(BallUMap))
            std::any_cast<BallUMap&>(_val).erase(key);
    }

    // String operations
    std::string substr(int64_t pos) const {
        if (_val.type() == typeid(std::string))
            return std::any_cast<const std::string&>(_val).substr(pos);
        return "";
    }
    std::string substr(int64_t pos, int64_t len) const {
        if (_val.type() == typeid(std::string))
            return std::any_cast<const std::string&>(_val).substr(pos, len);
        return "";
    }
    size_t find(const std::string& s, size_t pos = 0) const {
        if (_val.type() == typeid(std::string))
            return std::any_cast<const std::string&>(_val).find(s, pos);
        return std::string::npos;
    }

    // Comparison
    bool operator==(const BallDyn& o) const {
        if (!_val.has_value() && !o._val.has_value()) return true;
        if (!_val.has_value() || !o._val.has_value()) return false;
        if (_val.type() != o._val.type()) return false;
        if (_val.type() == typeid(int64_t)) return std::any_cast<int64_t>(_val) == std::any_cast<int64_t>(o._val);
        if (_val.type() == typeid(double)) return std::any_cast<double>(_val) == std::any_cast<double>(o._val);
        if (_val.type() == typeid(bool)) return std::any_cast<bool>(_val) == std::any_cast<bool>(o._val);
        if (_val.type() == typeid(std::string)) return std::any_cast<const std::string&>(_val) == std::any_cast<const std::string&>(o._val);
        return false;
    }
    bool operator!=(const BallDyn& o) const { return !(*this == o); }
    bool operator==(const std::string& s) const {
        if (_val.type() == typeid(std::string)) return std::any_cast<const std::string&>(_val) == s;
        return false;
    }
    bool operator!=(const std::string& s) const { return !(*this == s); }
    bool operator==(const char* s) const { return *this == std::string(s); }
    bool operator!=(const char* s) const { return !(*this == std::string(s)); }
    bool operator==(int64_t v) const {
        if (_val.type() == typeid(int64_t)) return std::any_cast<int64_t>(_val) == v;
        return false;
    }
    bool operator!=(int64_t v) const { return !(*this == v); }
    bool operator==(int v) const { return *this == static_cast<int64_t>(v); }
    bool operator!=(int v) const { return !(*this == static_cast<int64_t>(v)); }
    bool operator==(bool v) const {
        if (_val.type() == typeid(bool)) return std::any_cast<bool>(_val) == v;
        return false;
    }
    bool operator!=(bool v) const { return !(*this == v); }
    bool operator==(double v) const {
        if (_val.type() == typeid(double)) return std::any_cast<double>(_val) == v;
        return false;
    }
    bool operator!=(double v) const { return !(*this == v); }
    friend bool operator==(const std::string& s, const BallDyn& d) { return d == s; }
    friend bool operator!=(const std::string& s, const BallDyn& d) { return d != s; }
    friend bool operator==(int64_t v, const BallDyn& d) { return d == v; }
    friend bool operator!=(int64_t v, const BallDyn& d) { return d != v; }

    // Arithmetic operators for BallDyn
    BallDyn operator+(const BallDyn& o) const {
        // String concatenation
        if (_val.type() == typeid(std::string) || o._val.type() == typeid(std::string))
            return BallDyn(static_cast<std::string>(*this) + static_cast<std::string>(o));
        // Integer arithmetic
        if (_val.type() == typeid(int64_t) && o._val.type() == typeid(int64_t))
            return BallDyn(std::any_cast<int64_t>(_val) + std::any_cast<int64_t>(o._val));
        // Double arithmetic
        return BallDyn(static_cast<double>(*this) + static_cast<double>(o));
    }
    BallDyn operator-(const BallDyn& o) const {
        if (_val.type() == typeid(int64_t) && o._val.type() == typeid(int64_t))
            return BallDyn(std::any_cast<int64_t>(_val) - std::any_cast<int64_t>(o._val));
        return BallDyn(static_cast<double>(*this) - static_cast<double>(o));
    }
    BallDyn operator*(const BallDyn& o) const {
        if (_val.type() == typeid(int64_t) && o._val.type() == typeid(int64_t))
            return BallDyn(std::any_cast<int64_t>(_val) * std::any_cast<int64_t>(o._val));
        return BallDyn(static_cast<double>(*this) * static_cast<double>(o));
    }
    BallDyn operator/(const BallDyn& o) const {
        return BallDyn(static_cast<double>(*this) / static_cast<double>(o));
    }
    BallDyn operator%(const BallDyn& o) const {
        if (_val.type() == typeid(int64_t) && o._val.type() == typeid(int64_t))
            return BallDyn(std::any_cast<int64_t>(_val) % std::any_cast<int64_t>(o._val));
        return BallDyn(static_cast<int64_t>(static_cast<double>(*this)) %
                       static_cast<int64_t>(static_cast<double>(o)));
    }
    BallDyn operator-() const {
        if (_val.type() == typeid(int64_t)) return BallDyn(-std::any_cast<int64_t>(_val));
        if (_val.type() == typeid(double)) return BallDyn(-std::any_cast<double>(_val));
        return BallDyn();
    }
    // Comparison operators for ordering
    bool operator<(const BallDyn& o) const {
        if (_val.type() == typeid(int64_t) && o._val.type() == typeid(int64_t))
            return std::any_cast<int64_t>(_val) < std::any_cast<int64_t>(o._val);
        if (_val.type() == typeid(std::string) && o._val.type() == typeid(std::string))
            return std::any_cast<const std::string&>(_val) < std::any_cast<const std::string&>(o._val);
        return static_cast<double>(*this) < static_cast<double>(o);
    }
    bool operator>(const BallDyn& o) const { return o < *this; }
    bool operator<=(const BallDyn& o) const { return !(o < *this); }
    bool operator>=(const BallDyn& o) const { return !(*this < o); }

    // Arithmetic with int64_t
    BallDyn operator+(int64_t v) const {
        if (_val.type() == typeid(int64_t)) return BallDyn(std::any_cast<int64_t>(_val) + v);
        return BallDyn(static_cast<double>(*this) + v);
    }
    BallDyn operator-(int64_t v) const {
        if (_val.type() == typeid(int64_t)) return BallDyn(std::any_cast<int64_t>(_val) - v);
        return BallDyn(static_cast<double>(*this) - v);
    }
    friend BallDyn operator+(int64_t v, const BallDyn& d) { return d + v; }

    // String field access (Dart protobuf style: e.g. literal.stringValue)
    // Returns the value as a string, or empty if not a string.
    BallDyn __get_stringValue() const {
        // For protobuf-style access: obj["stringValue"] already works via operator[].
        // This is a convenience for `.stringValue` field access syntax.
        return (*this)["stringValue"s];
    }

    // indexOf: find an element in a BallDyn list, or a substring in a string.
    int64_t indexOf(const BallDyn& needle) const {
        if (_val.type() == typeid(BallList)) {
            auto& v = std::any_cast<const BallList&>(_val);
            for (size_t i = 0; i < v.size(); i++) {
                BallDyn el(v[i]);
                if (el == needle) return static_cast<int64_t>(i);
            }
            return -1;
        }
        if (_val.type() == typeid(std::string) && needle._val.type() == typeid(std::string)) {
            auto& s = std::any_cast<const std::string&>(_val);
            auto& n = std::any_cast<const std::string&>(needle._val);
            auto pos = s.find(n);
            return pos == std::string::npos ? -1 : static_cast<int64_t>(pos);
        }
        return -1;
    }

    // Iteration support (for range-based for loops over lists)
    struct Iterator {
        const BallList* list;
        size_t idx;
        BallDyn operator*() const { return BallDyn((*list)[idx]); }
        Iterator& operator++() { ++idx; return *this; }
        bool operator!=(const Iterator& o) const { return idx != o.idx; }
    };
    Iterator begin() const {
        if (_val.type() == typeid(BallList)) {
            auto& l = std::any_cast<const BallList&>(_val);
            return {&l, 0};
        }
        static BallList empty;
        return {&empty, 0};
    }
    Iterator end() const {
        if (_val.type() == typeid(BallList)) {
            auto& l = std::any_cast<const BallList&>(_val);
            return {&l, l.size()};
        }
        static BallList empty;
        return {&empty, 0};
    }

    // Function call
    BallDyn operator()(const BallDyn& arg) const {
        if (_val.type() == typeid(BallFunc)) {
            return BallDyn(std::any_cast<const BallFunc&>(_val)(arg._val));
        }
        return BallDyn();
    }
};

// Stream output
inline std::ostream& operator<<(std::ostream& os, const BallDyn& d) {
    return os << static_cast<std::string>(d);
}

// ball_to_string overload for BallDyn
inline std::string ball_to_string(const BallDyn& d) {
    return static_cast<std::string>(d);
}

// ============================================================
// Shared-pointer scope system
// ============================================================
// In Dart, maps are reference types. When the Dart engine is compiled
// to C++, scope maps need reference semantics so that mutations
// (e.g., incrementing a loop variable) propagate to all holders.
// We achieve this by storing scope maps as shared_ptr<BallMap>
// inside BallDyn's std::any. Copies of BallDyn share the same map.

using BallScope = std::shared_ptr<BallMap>;

// Helper to extract the BallMap* from a BallDyn that may hold
// either a BallScope (shared_ptr) or a plain BallMap.
inline BallMap* scope_map_ptr(std::any& val) {
    if (val.type() == typeid(BallScope))
        return std::any_cast<BallScope&>(val).get();
    if (val.type() == typeid(BallMap))
        return &std::any_cast<BallMap&>(val);
    return nullptr;
}
inline const BallMap* scope_map_cptr(const std::any& val) {
    if (val.type() == typeid(BallScope))
        return std::any_cast<const BallScope&>(val).get();
    if (val.type() == typeid(BallMap))
        return &std::any_cast<const BallMap&>(val);
    return nullptr;
}

// bind/child/resolve overloads for BallDyn
inline void bind(BallDyn& scope, const std::any& name, const std::any& value) {
    const std::any& rawName = (name.type() == typeid(BallDyn)) ? std::any_cast<const BallDyn&>(name)._val : name;
    const std::any& rawVal = (value.type() == typeid(BallDyn)) ? std::any_cast<const BallDyn&>(value)._val : value;
    auto* m = scope_map_ptr(scope._val);
    if (m) (*m)[ball_to_string(rawName)] = rawVal;
    else scope.set(ball_to_string(rawName), rawVal);
}
inline void bind(BallDyn& scope, const BallDyn& name, const BallDyn& value) {
    auto* m = scope_map_ptr(scope._val);
    if (m) (*m)[static_cast<std::string>(name)] = value._val;
    else scope.set(static_cast<std::string>(name), value._val);
}
inline void bind(BallDyn& scope, const std::string& name, const std::any& value) {
    const std::any& rawVal = (value.type() == typeid(BallDyn)) ? std::any_cast<const BallDyn&>(value)._val : value;
    auto* m = scope_map_ptr(scope._val);
    if (m) (*m)[name] = rawVal;
    else scope.set(name, rawVal);
}
inline BallDyn child(const BallDyn& scope) {
    auto newScope = std::make_shared<BallMap>();
    (*newScope)["__parent__"] = scope._val;
    return BallDyn(std::any(newScope));
}
inline std::any resolve(const BallDyn& scope, const std::string& name) {
    const BallMap* m = scope_map_cptr(scope._val);
    if (m) {
        auto it = m->find(name);
        if (it != m->end()) return it->second;
        auto pit = m->find("__parent__");
        if (pit != m->end()) return resolve(BallDyn(pit->second), name);
    }
    return resolve(scope._val, name);
}
// set_in_scope — walk the scope chain to find and update a variable.
// Unlike bind (which writes to the current scope), this walks __parent__ chain
// to find where the variable was originally defined, then updates it there.
inline void set_in_scope(std::any& scope, const std::string& key, const std::any& value);
inline void set_in_scope_map(BallMap& m, const std::string& key, const std::any& value) {
    auto it = m.find(key);
    if (it != m.end()) {
        m[key] = value;
        return;
    }
    auto pit = m.find("__parent__");
    if (pit != m.end() && pit->second.has_value()) {
        set_in_scope(pit->second, key, value);
        return;
    }
    // Fallback: bind in current scope
    m[key] = value;
}
inline void set_in_scope(std::any& scope, const std::string& key, const std::any& value) {
    if (scope.type() == typeid(BallScope)) {
        auto& ptr = std::any_cast<BallScope&>(scope);
        if (ptr) set_in_scope_map(*ptr, key, value);
        return;
    }
    if (scope.type() == typeid(BallMap)) {
        set_in_scope_map(std::any_cast<BallMap&>(scope), key, value);
        return;
    }
}

inline void set(BallDyn& scope, const BallDyn& name, const BallDyn& value) {
    std::string key = static_cast<std::string>(name);
    set_in_scope(scope._val, key, value._val);
}

// Overload for std::any scope
inline void set(std::any& scope, const BallDyn& name, const BallDyn& value) {
    std::string key = static_cast<std::string>(name);
    set_in_scope(scope, key, value._val);
}

// nextDouble overload for BallDyn (wrapping RandomType)
inline double nextDouble(const BallDyn&) {
    static RandomType fallback_random;
    return nextDouble(fallback_random);
}
inline int64_t nextInt(const BallDyn&, int64_t max_) {
    static RandomType fallback_random;
    return nextInt(fallback_random, max_);
}
inline int64_t nextInt(const BallDyn& r, const BallDyn& max_) {
    return nextInt(r, static_cast<int64_t>(max_));
}

// ── Self-hosted engine type stubs ──
// Types from the Dart Ball engine that are compiled to C++ but lack
// protobuf descriptors (so the compiler can't emit their struct bodies).
// Defined here as BallDyn wrappers so they inherit all BallDyn operations.
// Macro for defining a BallDyn-derived stub type with all constructors.
#define BALL_DYN_STUB(Name) \
    struct Name : public BallDyn { \
        using BallDyn::BallDyn; \
        using BallDyn::operator=; \
        Name() : BallDyn() {} \
        Name(const BallDyn& d) : BallDyn(d) {} \
        Name(BallDyn&& d) : BallDyn(std::move(d)) {} \
        Name& operator=(const BallDyn& d) { BallDyn::operator=(d); return *this; } \
    }

BALL_DYN_STUB(_FlowSignal);
BALL_DYN_STUB(_Scope);
BALL_DYN_STUB(BallRuntimeError);
BALL_DYN_STUB(BallFuture);
BALL_DYN_STUB(BallGenerator);
BALL_DYN_STUB(_ExitSignal);
BALL_DYN_STUB(BallModuleHandler);
BALL_DYN_STUB(StdModuleHandler);

#undef BALL_DYN_STUB

// ── ball_where / ball_map overloads for BallDyn ──
template<typename F>
inline BallList ball_where(const BallDyn& v, F pred) {
    BallList result;
    for (auto it = v.begin(); it != v.end(); ++it) {
        BallDyn el = *it;
        if (pred(el._val)) result.push_back(el._val);
    }
    return result;
}
template<typename F>
inline BallList ball_map(const BallDyn& v, F fn) {
    BallList result;
    for (auto it = v.begin(); it != v.end(); ++it) {
        BallDyn el = *it;
        result.push_back(fn(el._val));
    }
    return result;
}

// ball_set specialization for BallDyn — uses .set() method
// since BallDyn::operator[] returns by value.
template<>
inline void ball_set<BallDyn>(BallDyn& obj, const std::string& key, const std::any& value) {
    obj.set(key, value);
}
template<>
inline void ball_set<BallDyn>(BallDyn& obj, int64_t idx, const std::any& value) {
    obj.set(idx, value);
}
// ball_set with BallDyn value
inline void ball_set(BallDyn& obj, const std::string& key, const BallDyn& value) {
    obj.set(key, value._val);
}
inline void ball_set(BallDyn& obj, const BallDyn& key, const BallDyn& value) {
    obj.set(static_cast<std::string>(key), value._val);
}
// ball_set for std::map with BallDyn key
// Helper to unwrap BallDyn from std::any (MSVC wraps instead of converting)
inline std::any _unwrap_any(const std::any& v) {
    if (v.has_value() && v.type() == typeid(BallDyn))
        return std::any_cast<const BallDyn&>(v)._val;
    return v;
}
inline void ball_set(std::map<std::string, std::any>& m, const BallDyn& key, const std::any& value) {
    m[static_cast<std::string>(key)] = _unwrap_any(value);
}
inline void ball_set(std::unordered_map<std::string, std::any>& m, const BallDyn& key, const std::any& value) {
    m[static_cast<std::string>(key)] = _unwrap_any(value);
}

// String concatenation
inline std::string operator+(const std::string& s, const BallDyn& d) {
    return s + static_cast<std::string>(d);
}
inline std::string operator+(const BallDyn& d, const std::string& s) {
    return static_cast<std::string>(d) + s;
}

#endif  // BALL_DYN_H

// Full implementation of ball_to_string(const std::any&) with BallDyn support
inline std::string ball_to_string(const std::any& v) {
    if (!v.has_value()) return "null";
    if (v.type() == typeid(int64_t)) return std::to_string(std::any_cast<int64_t>(v));
    if (v.type() == typeid(int)) return std::to_string(std::any_cast<int>(v));
    if (v.type() == typeid(double)) return ball_to_string(std::any_cast<double>(v));
    if (v.type() == typeid(bool)) return ball_to_string(std::any_cast<bool>(v));
    if (v.type() == typeid(std::string)) return std::any_cast<std::string>(v);
    if (v.type() == typeid(const char*)) return std::any_cast<const char*>(v);
    if (v.type() == typeid(BallDyn)) return ball_to_string(std::any_cast<const BallDyn&>(v));
    if (v.type() == typeid(BallList)) return ball_to_string(std::any_cast<const BallList&>(v));
    return "<any>";
}

// Unwrap helper: extracts raw std::any from BallDyn, leaves std::any as-is.
// This prevents double-wrapping when BallDyn implicitly converts to std::any.
inline const std::any& _raw(const BallDyn& d) { return d._val; }
inline const std::any& _raw(const std::any& a) { return a; }

// BallDyn overload for ball_has_field — resolves implicit conversion ambiguity
// Also handles BallScope (shared_ptr<BallMap>) for scope reference semantics.
inline bool ball_has_field(const BallDyn& obj, const std::string& field) {
    if (obj._val.type() == typeid(BallScope)) {
        auto& ptr = std::any_cast<const BallScope&>(obj._val);
        if (!ptr) return false;
        auto it = ptr->find(field);
        return it != ptr->end() && it->second.has_value();
    }
    return ball_has_field(obj._val, field);
}

// BallDyn overloads for ball_which_* — same reason
inline std::string ball_which_expr(const BallDyn& obj) {
    if (obj._val.type() == typeid(BallDyn))
        return ball_which_expr(std::any_cast<const BallDyn&>(obj._val)._val);
    return ball_which_expr(obj._val);
}
inline std::string ball_which_value(const BallDyn& obj) {
    if (obj._val.type() == typeid(BallDyn))
        return ball_which_value(std::any_cast<const BallDyn&>(obj._val)._val);
    return ball_which_value(obj._val);
}
inline std::string ball_which_kind(const BallDyn& obj) {
    if (obj._val.type() == typeid(BallDyn))
        return ball_which_kind(std::any_cast<const BallDyn&>(obj._val)._val);
    return ball_which_kind(obj._val);
}
inline std::string ball_which_source(const BallDyn& obj) { return ball_which_source(obj._val); }
inline std::string ball_which_stmt(const BallDyn& obj) {
    if (obj._val.type() == typeid(BallDyn))
        return ball_which_stmt(std::any_cast<const BallDyn&>(obj._val)._val);
    return ball_which_stmt(obj._val);
}

// Helper to extract the raw std::any from any value, unwrapping BallDyn if present.
// Uses template to avoid ambiguity between std::any and BallDyn parameters.
// Recursively unwraps BallDyn-inside-std::any (MSVC wraps instead of converting).
template<typename T>
inline const std::any& _to_raw(const T& v) {
    if constexpr (std::is_same_v<T, BallDyn>) {
        // Recursively unwrap if _val itself holds a BallDyn
        if (v._val.type() == typeid(BallDyn))
            return _to_raw(std::any_cast<const BallDyn&>(v._val));
        return v._val;
    } else if constexpr (std::is_same_v<T, std::any>) {
        // If std::any holds a BallDyn, unwrap it
        if (v.type() == typeid(BallDyn))
            return _to_raw(std::any_cast<const BallDyn&>(v));
        return v;
    } else {
        // For other types, create a static std::any — fallback
        static thread_local std::any temp;
        temp = std::any(v);
        return temp;
    }
}

// Redefine ball_is_* as macros that unwrap BallDyn from std::any.
#undef ball_is_int
#undef ball_is_double
#undef ball_is_string
#undef ball_is_bool
#undef ball_is_map
#undef ball_is_list
#undef ball_is_function
#undef ball_is_flow_signal
#define ball_is_int(x) (_to_raw(x).has_value() && _to_raw(x).type() == typeid(int64_t))
#define ball_is_double(x) (_to_raw(x).has_value() && _to_raw(x).type() == typeid(double))
#define ball_is_string(x) (_to_raw(x).has_value() && _to_raw(x).type() == typeid(std::string))
#define ball_is_bool(x) (_to_raw(x).has_value() && _to_raw(x).type() == typeid(bool))
#define ball_is_map(x) (_to_raw(x).has_value() && (_to_raw(x).type() == typeid(BallMap) || _to_raw(x).type() == typeid(BallScope)))
#define ball_is_list(x) (_to_raw(x).has_value() && _to_raw(x).type() == typeid(BallList))
#define ball_is_function(x) (_to_raw(x).has_value() && _to_raw(x).type() == typeid(BallFunc))
#define ball_is_flow_signal(x) ([](const std::any& _v){ \
    if (!_v.has_value()) return false; \
    if (_v.type() == typeid(BallMap)) { const auto& _m = std::any_cast<const BallMap&>(_v); return _m.count("kind") > 0; } \
    if (_v.type() == typeid(BallScope)) { const auto& _p = std::any_cast<const BallScope&>(_v); return _p && _p->count("kind") > 0; } \
    return false; \
}(_to_raw(x)))

namespace {

// BallDyn overloads inside anonymous namespace for better overload resolution
inline bool ball_has_field_bd(const BallDyn& obj, const std::string& field) { return ball_has_field(obj._val, field); }
inline std::string ball_which_expr_bd(const BallDyn& obj) { return ball_which_expr(obj._val); }
inline std::string ball_which_value_bd(const BallDyn& obj) { return ball_which_value(obj._val); }
inline std::string ball_which_stmt_bd(const BallDyn& obj) { return ball_which_stmt(obj._val); }

// Scope operations for the self-hosted engine
// Scopes are BallDyn maps (either BallScope=shared_ptr<BallMap> or plain BallMap)
// with "__parent__" pointers forming a chain.
inline bool has(const BallDyn& scope, const BallDyn& name) {
    std::string key = static_cast<std::string>(name);
    const BallMap* m = scope_map_cptr(scope._val);
    if (m) {
        auto it = m->find(key);
        if (it != m->end() && it->second.has_value()) return true;
        auto pit = m->find("__parent__");
        if (pit != m->end() && pit->second.has_value()) return has(BallDyn(pit->second), name);
    }
    return false;
}
inline BallDyn lookup(const BallDyn& scope, const BallDyn& name) {
    std::string key = static_cast<std::string>(name);
    const BallMap* m = scope_map_cptr(scope._val);
    if (m) {
        auto it = m->find(key);
        if (it != m->end()) return BallDyn(it->second);
        auto pit = m->find("__parent__");
        if (pit != m->end() && pit->second.has_value()) return lookup(BallDyn(pit->second), name);
    }
    return BallDyn();
}
// Overloads for std::any scope
inline bool has(const std::any& scope, const BallDyn& name) {
    return has(BallDyn(scope), name);
}
inline BallDyn lookup(const std::any& scope, const BallDyn& name) {
    return lookup(BallDyn(scope), name);
}

struct BallEngine;
double _mathSqrt(double v);
double _mathPow(double a, double b);
double _mathLog(double v);
double _mathExp(double v);
double _mathSin(double v);
double _mathCos(double v);
double _mathTan(double v);
double _mathAsin(double v);
double _mathAcos(double v);
double _mathAtan(double v);
double _mathAtan2(double a, double b);

struct BallEngine {
    BallDyn program;
    BallDyn _types;
    BallDyn _functions;
    BallDyn _globalScope;
    BallDyn stdout_;
    std::string _currentModule;
    BallDyn _paramCache;
    BallDyn _callCache;
    BallDyn _enumValues;
    BallDyn _constructors;
    BallDyn _callCounts;
    BallDyn moduleHandlers;
    BallDyn _random;
    BallDyn stderr_;
    BallDyn stdinReader;
    BallDyn _envGet;
    BallDyn _args;
    int64_t _nextMutexId;
    BallDyn _activeException;
    BallDyn _resolver;
    BallDyn _initialized;
    BallDyn _stdFunctionToOperator() {
        return std::map<std::string,std::any>{{"type_args", std::any("String, String"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("equals"s)}, {"value", std::any("=="s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("not_equals"s)}, {"value", std::any("!="s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("add"s)}, {"value", std::any("+"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("subtract"s)}, {"value", std::any("-"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("multiply"s)}, {"value", std::any("*"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("divide"s)}, {"value", std::any("~/"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("divide_double"s)}, {"value", std::any("/"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("modulo"s)}, {"value", std::any("%"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("less_than"s)}, {"value", std::any("<"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("greater_than"s)}, {"value", std::any(">"s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("lte"s)}, {"value", std::any("<="s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("gte"s)}, {"value", std::any(">="s)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("index"s)}, {"value", std::any("[]"s)}})}};
    }
    BallDyn profilingReport() {
        return BallDyn(_callCounts ? BallDyn(_callCounts) : BallDyn(std::vector<std::any>{}));
    }
    BallDyn /* future */ callFunction(auto module, auto function, auto input) {
        return _resolveAndCallFunction(module, function, input);
    }
    void _buildLookupTables() {
        for (auto module : BallDyn(program)["modules"s]) {
            for (auto type : BallDyn(module)["types"s]) {
                ball_set(_types, BallDyn(type)["name"s], type);
                auto tc = BallDyn(type)["name"s].indexOf(":"s);
                if ((tc >= 0LL)) {
                    ball_set(_types, BallDyn(type)["name"s].substr((tc + 1LL)), type);
                }
            }
            for (auto td : BallDyn(module)["typeDefs"s]) {
                if (ball_has_field(td, "descriptor"s)) {
                    ball_set(_types, BallDyn(td)["name"s], BallDyn(td)["descriptor"s]);
                    auto tc = BallDyn(td)["name"s].indexOf(":"s);
                    if ((tc >= 0LL)) {
                        ball_set(_types, BallDyn(td)["name"s].substr((tc + 1LL)), BallDyn(td)["descriptor"s]);
                    }
                }
            }
            for (auto enumDesc : BallDyn(module)["enums"s]) {
                auto enumName = BallDyn(enumDesc)["name"s];
                auto values = std::map<std::string,std::any>{{"type_args", std::any("String, Map<String, Object?>"s)}};
                for (auto v : BallDyn(enumDesc)["value"s]) {
                    ball_set(values, BallDyn(v)["name"s], std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("__type__"s)}, {"value", std::any(enumName)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("name"s)}, {"value", std::any(BallDyn(v)["name"s])}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("index"s)}, {"value", std::any(BallDyn(v)["number"s])}})}});
                }
                ball_set(_enumValues, enumName, values);
                auto ec = enumName.indexOf(":"s);
                if ((ec >= 0LL)) {
                    ball_set(_enumValues, enumName.substr((ec + 1LL)), values);
                }
            }
            for (auto func : BallDyn(module)["functions"s]) {
                auto key = ((ball_to_string(BallDyn(module)["name"s]) + "."s) + ball_to_string(BallDyn(func)["name"s]));
                ball_set(_functions, key, func);
                if (ball_has_field(func, "metadata"s)) {
                    auto params = _extractParams(BallDyn(func)["metadata"s]);
                    if (!params.empty()) {
                        ball_set(_paramCache, key, params);
                    }
                    auto kindField = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["kind"s];
                    if (((kindField.has_value() ? kindField["stringValue"s] : BallDyn()) == "constructor"s)) {
                        auto entry = std::unordered_map<std::string, std::any>{{"module", std::any(BallDyn(module)["name"s])}, {"func", std::any(func)}};
                        auto dotIdx = BallDyn(func)["name"s].indexOf("."s);
                        if ((dotIdx >= 0LL)) {
                            auto className = BallDyn(func)["name"s].substr(0LL, dotIdx - 0LL);
                            auto ctorSuffix = BallDyn(func)["name"s].substr((dotIdx + 1LL));
                            if ((ctorSuffix == "new"s)) {
                                ball_set(_constructors, className, entry);
                                ball_set(_constructors, ((ball_to_string(BallDyn(module)["name"s]) + ":"s) + ball_to_string(className)), entry);
                            }
                            ball_set(_constructors, BallDyn(func)["name"s], entry);
                        }
                    }
                }
            }
        }
    }
    BallDyn /* future */ _initTopLevelVariables() {
        for (auto module : BallDyn(program)["modules"s]) {
            if (((BallDyn(module)["name"s] == "std"s) || (BallDyn(module)["name"s] == "dart_std"s))) {
                continue;
            }
            for (auto func : BallDyn(module)["functions"s]) {
                if ((!ball_has_field(func, "metadata"s))) {
                    continue;
                }
                auto kindValue = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["kind"s];
                if (((kindValue.has_value() ? kindValue["stringValue"s] : BallDyn()) != "top_level_variable"s)) {
                    continue;
                }
                (_currentModule = BallDyn(module)["name"s]);
                auto value = (BallDyn(ball_has_field(func, "body"s) ? BallDyn(_evalExpression(BallDyn(func)["body"s], _globalScope)) : BallDyn(BallDyn())));
                _globalScope.set(static_cast<std::string>(BallDyn(func)["name"s]), value._val);
            }
        }
    }
    BallDyn /* future */ run() {
        _initialized;
        auto key = ((ball_to_string(BallDyn(program)["entryModule"s]) + "."s) + ball_to_string(BallDyn(program)["entryFunction"s]));
        auto entryFunc = BallDyn(_functions)[key];
        if (!BallDyn(entryFunc).has_value()) {
            throw BallException("Exception"s, "Exception"s, std::map<std::string, std::string>{});
        }
        (_currentModule = BallDyn(program)["entryModule"s]);
        return _callFunction(BallDyn(program)["entryModule"s], entryFunc, BallDyn());
    }
    BallDyn /* future */ _callFunction(auto moduleName, auto func, auto input) {
        if (BallDyn(func)["isBase"s]) {
            return _callBaseFunction(moduleName, BallDyn(func)["name"s], input);
        }
        if ((!ball_has_field(func, "body"s))) {
            return BallDyn();
        }
        auto prevModule = _currentModule;
        (_currentModule = moduleName);
        auto scope = child(_globalScope);
        auto params = BallDyn(BallDyn(_paramCache)[((ball_to_string(moduleName) + "."s) + ball_to_string(BallDyn(func)["name"s]))] ? BallDyn(BallDyn(_paramCache)[((ball_to_string(moduleName) + "."s) + ball_to_string(BallDyn(func)["name"s]))]) : BallDyn(((BallDyn(ball_has_field(func, "metadata"s) ? BallDyn(_extractParams(BallDyn(func)["metadata"s])) : BallDyn(std::vector<std::any>{}))))));
        if (!params.empty()) {
            if (((static_cast<int64_t>(params.size()) == 1LL) && (!(ball_is_map(input) && (input.count("self"s) > 0))))) {
                scope.set(static_cast<std::string>(BallDyn(params)[0LL]), BallDyn(input)._val);
            } else {
                if (ball_is_map(input)) {
                    for (auto i = 0; (i < static_cast<int64_t>(params.size())); (i++)) {
                        auto p = BallDyn(params)[i];
                        std::string pStr = static_cast<std::string>(p);
                        if ((input.count(pStr) > 0)) {
                            scope.set(pStr, BallDyn(input)[pStr]._val);
                        } else {
                            std::string argKey = "arg"s + ball_to_string(i);
                            if ((input.count(argKey) > 0)) {
                                scope.set(pStr, BallDyn(input)[argKey]._val);
                            }
                        }
                    }
                } else {
                    if (ball_is_list(input)) {
                        for (auto i = 0; ((i < static_cast<int64_t>(params.size())) && (i < static_cast<int64_t>(input.size()))); (i++)) {
                            scope.set(static_cast<std::string>(BallDyn(params)[i]), BallDyn(input)[i]._val);
                        }
                    }
                }
            }
        }
        if ((ball_is_map(input) && (input.count("self"s) > 0))) {
            scope.set("self"s, BallDyn(input)["self"s]._val);
        }
        if ((!BallDyn(func)["inputType"s].empty() && BallDyn(input).has_value())) {
            scope.set("input"s, BallDyn(input)._val);
        }
        auto result = _evalExpression(BallDyn(func)["body"s], scope);
        (_currentModule = prevModule);
        auto finalResult = BallDyn();
        if ((ball_is_flow_signal(result) && (BallDyn(result)["kind"s] == "return"s))) {
            (finalResult = BallDyn(result)["value"s]);
        } else {
            (finalResult = result);
        }
        if (ball_has_field(func, "metadata"s)) {
            auto asyncField = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["is_async"s];
            auto generatorField = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["is_generator"s];
            if ((BallDyn(asyncField).has_value() && BallDyn(asyncField)["boolValue"s])) {
                if (!(ball_object_type_matches(finalResult, "BallFuture"s))) {
                    return BallFuture(finalResult);
                }
            }
            if ((BallDyn(generatorField).has_value() && BallDyn(generatorField)["boolValue"s])) {
                if (ball_object_type_matches(finalResult, "BallGenerator"s)) {
                    return BallDyn(finalResult)["values"s];
                }
                if (ball_is_list(finalResult)) {
                    return finalResult;
                }
                return std::vector<std::any>{std::any(finalResult)};
            }
        }
        return finalResult;
    }
    std::vector<std::any> _extractParams(auto metadata) {
        auto paramsValue = BallDyn(BallDyn(metadata)["fields"s])["params"s];
        if ((!BallDyn(paramsValue).has_value() || (ball_which_kind(paramsValue) != "listValue"s))) {
            return std::vector<std::any>{};
        }
        std::vector<std::any> result;
        auto values = BallDyn(BallDyn(paramsValue)["listValue"s])["values"s];
        for (auto v : values) {
            if (ball_which_kind(v) != "structValue"s) continue;
            auto nameField = BallDyn(BallDyn(BallDyn(v)["structValue"s])["fields"s])["name"s];
            if (!BallDyn(nameField).has_value()) continue;
            std::string name = static_cast<std::string>(BallDyn(nameField)["stringValue"s]);
            if (!name.empty()) {
                result.push_back(std::any(name));
            }
        }
        return result;
    }
    BallDyn /* future */ _resolveAndCallFunction(auto module, auto function, auto input) {
        auto moduleName = (BallDyn(module.empty() ? BallDyn(_currentModule) : BallDyn(module)));
        auto key = ((ball_to_string(moduleName) + "."s) + ball_to_string(function));
        auto func = BallDyn(_functions)[key];
        if (BallDyn(func).has_value()) {
            return _callFunction(moduleName, func, input);
        }
        auto cached = BallDyn(_callCache)[function];
        if (BallDyn(cached).has_value()) {
            return _callFunction(BallDyn(cached)["module"s], BallDyn(cached)["func"s], input);
        }
        for (auto m : BallDyn(program)["modules"s]) {
            for (auto f : BallDyn(m)["functions"s]) {
                if ((BallDyn(f)["name"s] == function)) {
                    ball_set(_callCache, function, std::unordered_map<std::string, std::any>{{"module", std::any(BallDyn(m)["name"s])}, {"func", std::any(f)}});
                    return _callFunction(BallDyn(m)["name"s], f, input);
                }
            }
        }
        auto ctorKey = (((ball_to_string(moduleName) + "."s) + ball_to_string(function)) + ".new"s);
        auto ctorFunc = BallDyn(_functions)[ctorKey];
        if (BallDyn(ctorFunc).has_value()) {
            return _callFunction(moduleName, ctorFunc, input);
        }
        auto ctorEntry = BallDyn(_constructors)[function];
        if (BallDyn(ctorEntry).has_value()) {
            return _callFunction(BallDyn(ctorEntry)["module"s], BallDyn(ctorEntry)["func"s], input);
        }
        if (BallDyn(_resolver).has_value()) {
            auto resolved = _tryLazyResolve(moduleName);
            if (BallDyn(resolved).has_value()) {
                _indexModule(resolved);
                auto resolvedFunc = BallDyn(_functions)[((ball_to_string(moduleName) + "."s) + ball_to_string(function))];
                if (BallDyn(resolvedFunc).has_value()) {
                    return _callFunction(moduleName, resolvedFunc, input);
                }
            }
        }
        throw BallException("Exception"s, "Exception"s, std::map<std::string, std::string>{});
    }
    BallDyn /* future */ _tryLazyResolve(auto moduleName) {
        for (auto m : BallDyn(program)["modules"s]) {
            for (auto import_ : BallDyn(m)["moduleImports"s]) {
                if (((BallDyn(import_)["name"s] == moduleName) && (ball_which_source(import_) != "notSet"s))) {
                    try {
                        return resolve(_resolver, import_);
                    } catch (const std::exception& __ball_e) {
                        std::string _ = __ball_e.what();
                    }
                }
            }
        }
        return BallDyn();
    }
    void _indexModule(auto module) {
        BallDyn(program)["modules"s].push_back(module);
        for (auto type : BallDyn(module)["types"s]) {
            ball_set(_types, BallDyn(type)["name"s], type);
        }
        for (auto td : BallDyn(module)["typeDefs"s]) {
            if (ball_has_field(td, "descriptor"s)) {
                ball_set(_types, BallDyn(td)["name"s], BallDyn(td)["descriptor"s]);
            }
        }
        for (auto func : BallDyn(module)["functions"s]) {
            auto key = ((ball_to_string(BallDyn(module)["name"s]) + "."s) + ball_to_string(BallDyn(func)["name"s]));
            ball_set(_functions, key, func);
            if (ball_has_field(func, "metadata"s)) {
                auto params = _extractParams(BallDyn(func)["metadata"s]);
                if (!params.empty()) {
                    ball_set(_paramCache, key, params);
                }
                auto kindField = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["kind"s];
                if (((kindField.has_value() ? kindField["stringValue"s] : BallDyn()) == "constructor"s)) {
                    auto entry = std::unordered_map<std::string, std::any>{{"module", std::any(BallDyn(module)["name"s])}, {"func", std::any(func)}};
                    auto dotIdx = BallDyn(func)["name"s].indexOf("."s);
                    if ((dotIdx >= 0LL)) {
                        auto className = BallDyn(func)["name"s].substr(0LL, dotIdx - 0LL);
                        auto ctorSuffix = BallDyn(func)["name"s].substr((dotIdx + 1LL));
                        if ((ctorSuffix == "new"s)) {
                            ball_set(_constructors, className, entry);
                            ball_set(_constructors, ((ball_to_string(BallDyn(module)["name"s]) + ":"s) + ball_to_string(className)), entry);
                        }
                        ball_set(_constructors, BallDyn(func)["name"s], entry);
                    }
                }
            }
        }
    }
    BallDyn /* future */ _evalExpression(auto expr, BallDyn& scope) {
        auto which = ball_which_expr_bd(BallDyn(expr));
        if (which == "call"s) return _evalCall(BallDyn(expr)["call"s], scope);
        if (which == "literal"s) return _evalLiteral(BallDyn(expr)["literal"s], scope);
        if (which == "reference"s) return _evalReference(BallDyn(expr)["reference"s], scope);
        if (which == "fieldAccess"s) return _evalFieldAccess(BallDyn(expr)["fieldAccess"s], scope);
        if (which == "messageCreation"s) return _evalMessageCreation(BallDyn(expr)["messageCreation"s], scope);
        if (which == "block"s) return _evalBlock(BallDyn(expr)["block"s], scope);
        if (which == "lambda"s) return _evalLambda(BallDyn(expr)["lambda"s], scope);
        return BallDyn();
    }
    BallDyn /* future */ _evalCall(auto call, BallDyn& scope) {
        auto moduleName = (BallDyn(BallDyn(call)["module"s].empty() ? BallDyn(_currentModule) : BallDyn(BallDyn(call)["module"s])));
        if (((moduleName == "std"s) || (moduleName == "dart_std"s))) {
            auto fn = BallDyn(call)["function"s];
            if (fn == "if"s) return _evalLazyIf(call, scope);
            if (fn == "for"s) return _evalLazyFor(call, scope);
            if (fn == "for_in"s || fn == "for_each"s) return _evalLazyForIn(call, scope);
            if (fn == "while"s) return _evalLazyWhile(call, scope);
            if (fn == "do_while"s) return _evalLazyDoWhile(call, scope);
            if (fn == "switch_expr"s || fn == "switch"s) return _evalLazySwitch(call, scope);
            if (fn == "try"s) return _evalLazyTry(call, scope);
            if (fn == "labeled"s) return _evalLabeled(call, scope);
            if (fn == "assign"s) return _evalAssign(call, scope);
            if (fn == "return"s) return _evalReturn(call, scope);
            if (fn == "break"s) return _evalBreak(call, scope);
            if (fn == "continue"s) return _evalContinue(call, scope);
            if (fn == "pre_increment"s || fn == "post_increment"s ||
                fn == "pre_decrement"s || fn == "post_decrement"s)
                return _evalIncDec(call, scope);
            if (fn == "and"s) return _evalShortCircuitAnd(call, scope);
            if (fn == "or"s) return _evalShortCircuitOr(call, scope);
            if (fn == "for_in_map"s) return _evalLazyForIn(call, scope);
            if (fn == "await_for"s) return _evalAwaitFor(call, scope);
            if (fn == "goto"s) return _evalGoto(call, scope);
            if (fn == "label"s) return _evalLabel(call, scope);
        }
        if (((moduleName == "cpp_std"s) && (BallDyn(call)["function"s] == "cpp_scope_exit"s))) {
            return _evalCppScopeExit(call, scope);
        }
        auto input = (BallDyn(ball_has_field(call, "input"s) ? BallDyn(_evalExpression(BallDyn(call)["input"s], scope)) : BallDyn(BallDyn())));
        if (((BallDyn(call)["module"s] == "std"s) || (BallDyn(call)["module"s] == "dart_std"s))) {
            return _callBaseFunction(BallDyn(call)["module"s], BallDyn(call)["function"s], input);
        }
        auto key = ((ball_to_string(moduleName) + "."s) + ball_to_string(BallDyn(call)["function"s]));
        auto func = BallDyn(_functions)[key];
        if ((BallDyn(func).has_value() && BallDyn(func)["isBase"s])) {
            return _callBaseFunction(moduleName, BallDyn(call)["function"s], input);
        }
        if ((BallDyn(call)["module"s].empty() && has(scope, BallDyn(call)["function"s]))) {
            auto bound = lookup(scope, BallDyn(call)["function"s]);
            if (ball_is_function(bound)) {
                auto result = bound(input);
                if (ball_object_type_matches(result, "Future"s)) {
                    return result;
                }
                return result;
            }
        }
        if ((ball_is_map(input) && (input.count("self"s) > 0))) {
            auto self = BallDyn(input)["self"s];
            if (ball_is_map(self)) {
                auto typeName = BallDyn(self)["__type__"s];
                if (BallDyn(typeName).has_value()) {
                    auto colonIdx = typeName.indexOf(":"s);
                    auto modPart = (BallDyn((colonIdx >= 0LL) ? BallDyn(typeName.substr(0LL, colonIdx - 0LL)) : BallDyn(_currentModule)));
                    auto methodKey = ((((ball_to_string(modPart) + "."s) + ball_to_string(typeName)) + "."s) + ball_to_string(BallDyn(call)["function"s]));
                    auto method = BallDyn(_functions)[methodKey];
                    if (BallDyn(method).has_value()) {
                        return _callFunction(modPart, method, input);
                    }
                    auto super_ = BallDyn(self)["__super__"s];
                    while (ball_is_map(super_)) {
                        auto superType = BallDyn(super_)["__type__"s];
                        if (BallDyn(superType).has_value()) {
                            auto sColonIdx = superType.indexOf(":"s);
                            auto sModPart = (BallDyn((sColonIdx >= 0LL) ? BallDyn(superType.substr(0LL, sColonIdx - 0LL)) : BallDyn(modPart)));
                            auto sTypeName = (BallDyn((sColonIdx >= 0LL) ? BallDyn(superType) : BallDyn(((ball_to_string(sModPart) + ":"s) + ball_to_string(superType)))));
                            auto superMethodKey = ((((ball_to_string(sModPart) + "."s) + ball_to_string(sTypeName)) + "."s) + ball_to_string(BallDyn(call)["function"s]));
                            auto superMethod = BallDyn(_functions)[superMethodKey];
                            if (BallDyn(superMethod).has_value()) {
                                return _callFunction(sModPart, superMethod, input);
                            }
                        }
                        (super_ = BallDyn(super_)["__super__"s]);
                    }
                }
            }
        }
        return _resolveAndCallFunction(BallDyn(call)["module"s], BallDyn(call)["function"s], input);
    }
    BallDyn /* future */ _evalLiteral(auto lit, BallDyn& scope) {
        auto which = ball_which_value(lit);
        if (which == "intValue"s) {
            auto v = BallDyn(lit)["intValue"s];
            // intValue may come as string from JSON (int64), convert to int64_t
            if (v._val.type() == typeid(std::string)) {
                try { return BallDyn(static_cast<int64_t>(std::stoll(std::any_cast<std::string>(v._val)))); }
                catch (...) { return BallDyn(int64_t(0)); }
            }
            if (v._val.type() == typeid(double)) return BallDyn(static_cast<int64_t>(std::any_cast<double>(v._val)));
            return v;
        }
        if (which == "doubleValue"s) return BallDyn(lit)["doubleValue"s];
        if (which == "stringValue"s) return BallDyn(lit)["stringValue"s];
        if (which == "boolValue"s) return BallDyn(lit)["boolValue"s];
        if (which == "bytesValue"s) return BallDyn(lit)["bytesValue"s];
        if (which == "listValue"s) return _evalListLiteral(BallDyn(lit)["listValue"s], scope);
        return BallDyn();
    }
    BallDyn /* future */ _evalListLiteral(auto listVal, BallDyn& scope) {
        auto result = std::vector<std::any>{};
        for (auto element : BallDyn(listVal)["elements"s]) {
            if (ball_has_field(element, "call"s)) {
                auto call = BallDyn(element)["call"s];
                auto fn = BallDyn(call)["function"s];
                if ((((BallDyn(call)["module"s] == "dart_std"s) || (BallDyn(call)["module"s] == "std"s)) && (fn == "collection_if"s))) {
                    _evalCollectionIf(call, scope, result);
                    continue;
                }
                if ((((BallDyn(call)["module"s] == "dart_std"s) || (BallDyn(call)["module"s] == "std"s)) && (fn == "collection_for"s))) {
                    _evalCollectionFor(call, scope, result);
                    continue;
                }
            }
            result.push_back(_evalExpression(element, scope));
        }
        return result;
    }
    BallDyn /* future */ _evalCollectionIf(auto call, BallDyn& scope, auto result) {
        auto fields = _lazyFields(call);
        auto condExpr = BallDyn(fields)["condition"s];
        if (!BallDyn(condExpr).has_value()) {
            return BallDyn();
        }
        auto cond = _toBool(_evalExpression(condExpr, scope));
        if (cond) {
            auto thenExpr = BallDyn(fields)["then"s];
            if (BallDyn(thenExpr).has_value()) {
                _addCollectionElement(thenExpr, scope, result);
            }
        } else {
            auto elseExpr = BallDyn(fields)["else"s];
            if (BallDyn(elseExpr).has_value()) {
                _addCollectionElement(elseExpr, scope, result);
            }
        }
    }
    BallDyn /* future */ _evalCollectionFor(auto call, BallDyn& scope, auto result) {
        auto fields = _lazyFields(call);
        auto variable = _stringFieldVal(fields, "variable"s);
        auto iterableExpr = BallDyn(fields)["iterable"s];
        auto bodyExpr = BallDyn(fields)["body"s];
        if ((!BallDyn(iterableExpr).has_value() || !BallDyn(bodyExpr).has_value())) {
            return BallDyn();
        }
        auto iterable = _evalExpression(iterableExpr, scope);
        if (!(ball_is_list(iterable))) {
            return BallDyn();
        }
        for (auto item : iterable) {
            auto loopScope = child(scope);
            bind(loopScope, (BallDyn(BallDyn(variable ? BallDyn(variable) : BallDyn(""s)).empty() ? BallDyn("item"s) : BallDyn(variable))), item);
            _addCollectionElement(bodyExpr, loopScope, result);
        }
    }
    BallDyn /* future */ _addCollectionElement(auto expr, BallDyn& scope, auto result) {
        if (ball_has_field(expr, "call"s)) {
            auto call = BallDyn(expr)["call"s];
            auto fn = BallDyn(call)["function"s];
            if ((((BallDyn(call)["module"s] == "dart_std"s) || (BallDyn(call)["module"s] == "std"s)) && (fn == "collection_if"s))) {
                _evalCollectionIf(call, scope, result);
                return BallDyn();
            }
            if ((((BallDyn(call)["module"s] == "dart_std"s) || (BallDyn(call)["module"s] == "std"s)) && (fn == "collection_for"s))) {
                _evalCollectionFor(call, scope, result);
                return BallDyn();
            }
        }
        result.push_back(_evalExpression(expr, scope));
    }
    BallDyn /* future */ _evalReference(auto ref, BallDyn& scope) {
        auto name = BallDyn(ref)["name"s];
        if (has(scope, name)) {
            return lookup(scope, name);
        }
        auto ctorEntry = BallDyn(_constructors)[name];
        if (BallDyn(ctorEntry).has_value()) {
            return BallDyn(BallFunc([=, this](std::any input) mutable -> std::any {
                return _callFunction(BallDyn(ctorEntry)["module"s], BallDyn(ctorEntry)["func"s], BallDyn(input))._val;
            }));
        }
        auto colonIdx = name.indexOf(":"s);
        if ((colonIdx >= 0LL)) {
            auto bare = name.substr((colonIdx + 1LL));
            auto bareEntry = BallDyn(_constructors)[bare];
            if (BallDyn(bareEntry).has_value()) {
                return BallDyn(BallFunc([=, this](std::any input) mutable -> std::any {
                    return _callFunction(BallDyn(bareEntry)["module"s], BallDyn(bareEntry)["func"s], BallDyn(input))._val;
                }));
            }
        }
        auto enumVals = BallDyn(_enumValues)[name];
        if (BallDyn(enumVals).has_value()) {
            return enumVals;
        }
        auto getterKey = ((ball_to_string(_currentModule) + "."s) + ball_to_string(name));
        auto getterFunc = BallDyn(_functions)[getterKey];
        if ((BallDyn(getterFunc).has_value() && _isGetter(getterFunc))) {
            return _callFunction(_currentModule, getterFunc, BallDyn());
        }
        return lookup(scope, name);
    }
    BallDyn /* future */ _evalFieldAccess(auto access, BallDyn& scope) {
        auto object = _evalExpression(BallDyn(access)["object"s], scope);
        auto fieldName = BallDyn(access)["field"s];
        if (ball_is_map(object)) {
            if ((object.count(fieldName) > 0)) {
                return BallDyn(object)[fieldName];
            }
            auto superObj = BallDyn(object)["__super__"s];
            while (ball_is_map(superObj)) {
                if ((superObj.count(fieldName) > 0)) {
                    return BallDyn(superObj)[fieldName];
                }
                (superObj = BallDyn(superObj)["__super__"s]);
            }
            auto methods = BallDyn(object)["__methods__"s];
            if ((ball_is_map(methods) && (methods.count(fieldName) > 0))) {
                return BallDyn(methods)[fieldName];
            }
            (superObj = BallDyn(object)["__super__"s]);
            while (ball_is_map(superObj)) {
                auto superMethods = BallDyn(superObj)["__methods__"s];
                if ((ball_is_map(superMethods) && (superMethods.count(fieldName) > 0))) {
                    return BallDyn(superMethods)[fieldName];
                }
                (superObj = BallDyn(superObj)["__super__"s]);
            }
            auto getterResult = _tryGetterDispatch(object, fieldName);
            if ((getterResult != BallDyn())) {
                return getterResult;
            }
            // Built-in map property access (after getter dispatch)
            return _builtinFieldAccess(object, fieldName);
        }
        // Built-in field access for non-map types
        return _builtinFieldAccess(object, fieldName);
    }
    BallDyn /* future */ _tryGetterDispatch(auto object, auto fieldName) {
        auto typeName = BallDyn(object)["__type__"s];
        if (!BallDyn(typeName).has_value()) {
            return BallDyn();
        }
        auto colonIdx = typeName.indexOf(":"s);
        auto modPart = (BallDyn((colonIdx >= 0LL) ? BallDyn(typeName.substr(0LL, colonIdx - 0LL)) : BallDyn(_currentModule)));
        auto getterKey = ((((ball_to_string(modPart) + "."s) + ball_to_string(typeName)) + "."s) + ball_to_string(fieldName));
        auto getterFunc = BallDyn(_functions)[getterKey];
        if ((BallDyn(getterFunc).has_value() && _isGetter(getterFunc))) {
            return _callFunction(modPart, getterFunc, std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("self"s)}, {"value", std::any(object)}})}});
        }
        auto superObj = BallDyn(object)["__super__"s];
        while (ball_is_map(superObj)) {
            auto superType = BallDyn(superObj)["__type__"s];
            if (BallDyn(superType).has_value()) {
                auto sColonIdx = superType.indexOf(":"s);
                auto sModPart = (BallDyn((sColonIdx >= 0LL) ? BallDyn(superType.substr(0LL, sColonIdx - 0LL)) : BallDyn(modPart)));
                auto sTypeName = (BallDyn((sColonIdx >= 0LL) ? BallDyn(superType) : BallDyn(((ball_to_string(sModPart) + ":"s) + ball_to_string(superType)))));
                auto superGetterKey = ((((ball_to_string(sModPart) + "."s) + ball_to_string(sTypeName)) + "."s) + ball_to_string(fieldName));
                auto superGetterFunc = BallDyn(_functions)[superGetterKey];
                if ((BallDyn(superGetterFunc).has_value() && _isGetter(superGetterFunc))) {
                    return _callFunction(sModPart, superGetterFunc, std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("self"s)}, {"value", std::any(object)}})}});
                }
            }
            (superObj = BallDyn(superObj)["__super__"s]);
        }
        return BallDyn();
    }
    bool _isGetter(auto func) {
        if ((!ball_has_field(func, "metadata"s))) {
            return false;
        }
        auto field = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["is_getter"s];
        return (BallDyn(field).has_value() && BallDyn(field)["boolValue"s]);
    }
    bool _isSetter(auto func) {
        if ((!ball_has_field(func, "metadata"s))) {
            return false;
        }
        auto field = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["is_setter"s];
        return (BallDyn(field).has_value() && BallDyn(field)["boolValue"s]);
    }
    BallDyn /* future */ _trySetterDispatch(auto object, auto fieldName, auto value) {
        auto typeName = BallDyn(object)["__type__"s];
        if (!BallDyn(typeName).has_value()) {
            return BallDyn();
        }
        auto colonIdx = typeName.indexOf(":"s);
        auto modPart = (BallDyn((colonIdx >= 0LL) ? BallDyn(typeName.substr(0LL, colonIdx - 0LL)) : BallDyn(_currentModule)));
        auto setterKey = (((((ball_to_string(modPart) + "."s) + ball_to_string(typeName)) + "."s) + ball_to_string(fieldName)) + "="s);
        auto setterFunc = BallDyn(_functions)[setterKey];
        if ((BallDyn(setterFunc).has_value() && _isSetter(setterFunc))) {
            return _callFunction(modPart, setterFunc, std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("self"s)}, {"value", std::any(object)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("value"s)}, {"value", std::any(value)}})}});
        }
        auto superObj = BallDyn(object)["__super__"s];
        while (ball_is_map(superObj)) {
            auto superType = BallDyn(superObj)["__type__"s];
            if (BallDyn(superType).has_value()) {
                auto sColonIdx = superType.indexOf(":"s);
                auto sModPart = (BallDyn((sColonIdx >= 0LL) ? BallDyn(superType.substr(0LL, sColonIdx - 0LL)) : BallDyn(modPart)));
                auto sTypeName = (BallDyn((sColonIdx >= 0LL) ? BallDyn(superType) : BallDyn(((ball_to_string(sModPart) + ":"s) + ball_to_string(superType)))));
                auto superSetterKey = (((((ball_to_string(sModPart) + "."s) + ball_to_string(sTypeName)) + "."s) + ball_to_string(fieldName)) + "="s);
                auto superSetterFunc = BallDyn(_functions)[superSetterKey];
                if ((BallDyn(superSetterFunc).has_value() && _isSetter(superSetterFunc))) {
                    return _callFunction(sModPart, superSetterFunc, std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("self"s)}, {"value", std::any(object)}})}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("value"s)}, {"value", std::any(value)}})}});
                }
            }
            (superObj = BallDyn(superObj)["__super__"s]);
        }
        return BallDyn();
    }
    BallDyn /* future */ _evalMessageCreation(auto msg, BallDyn& scope) {
        auto fields = std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}};
        for (auto pair : BallDyn(msg)["fields"s]) {
            auto val = _evalExpression(BallDyn(pair)["value"s], scope);
            ball_set(fields, BallDyn(pair)["name"s], val._val);
        }
        if (!BallDyn(msg)["typeName"s].empty()) {
            ball_set(fields, "__type__"s, BallDyn(msg)["typeName"s]);
            auto genMatch = ball_first_match(std::regex("^(\\w+)<(.+)>$"s), BallDyn(msg)["typeName"s]);
            if (BallDyn(genMatch).has_value()) {
                ball_set(fields, "__type__"s, ball_group(genMatch, 1LL));
                ball_set(fields, "__type_args__"s, _splitTypeArgs(ball_group(genMatch, 2LL)));
            }
            auto typeDef = _findTypeDef(BallDyn(msg)["typeName"s]);
            if (BallDyn(typeDef).has_value()) {
                auto superclass = _getMetaString(typeDef, "superclass"s);
                if ((BallDyn(superclass).has_value() && !superclass.empty())) {
                    ball_set(fields, "__super__"s, _buildSuperObject(superclass, fields));
                }
                auto methods = _resolveTypeMethodsWithInheritance(BallDyn(msg)["typeName"s]);
                if (!methods.empty()) {
                    ball_set(fields, "__methods__"s, methods);
                }
            }
        }
        return fields;
    }
    BallDyn _builtinFieldAccess(BallDyn object, BallDyn fieldName) {
        std::string fn = static_cast<std::string>(fieldName);
        // String properties
        if (ball_is_string(object)) {
            std::string s = static_cast<std::string>(object);
            if (fn == "length") return BallDyn(static_cast<int64_t>(s.size()));
            if (fn == "isEmpty") return BallDyn(s.empty());
            if (fn == "isNotEmpty") return BallDyn(!s.empty());
            if (fn == "runes" || fn == "codeUnits") {
                BallList r; for (unsigned char c : s) r.push_back(std::any(static_cast<int64_t>(c)));
                return BallDyn(r);
            }
        }
        // List properties
        if (ball_is_list(object)) {
            auto& l = std::any_cast<const BallList&>(_to_raw(object));
            if (fn == "length") return BallDyn(static_cast<int64_t>(l.size()));
            if (fn == "isEmpty") return BallDyn(l.empty());
            if (fn == "isNotEmpty") return BallDyn(!l.empty());
            if (fn == "first") return l.empty() ? BallDyn() : BallDyn(l.front());
            if (fn == "last") return l.empty() ? BallDyn() : BallDyn(l.back());
            if (fn == "reversed") { BallList rev(l.rbegin(), l.rend()); return BallDyn(rev); }
        }
        // Map properties
        if (ball_is_map(object)) {
            if (fn == "length") return BallDyn(static_cast<int64_t>(object.size()));
            if (fn == "isEmpty") return BallDyn(object.empty());
            if (fn == "isNotEmpty") return BallDyn(!object.empty());
            if (fn == "keys") {
                BallList keys;
                const BallMap* m = scope_map_cptr(object._val);
                if (m) for (auto& [k,v] : *m) if (k.find("__") != 0 && k != "type_args") keys.push_back(std::any(k));
                return BallDyn(keys);
            }
            if (fn == "values") {
                BallList vals;
                const BallMap* m = scope_map_cptr(object._val);
                if (m) for (auto& [k,v] : *m) if (k.find("__") != 0 && k != "type_args") vals.push_back(v);
                return BallDyn(vals);
            }
            if (fn == "entries") {
                BallList entries;
                const BallMap* m = scope_map_cptr(object._val);
                if (m) for (auto& [k,v] : *m) if (k.find("__") != 0 && k != "type_args") entries.push_back(std::any(BallMap{{"key", std::any(k)}, {"value", v}}));
                return BallDyn(entries);
            }
        }
        // Numeric properties
        if (ball_is_int(object) || ball_is_double(object)) {
            double d = static_cast<double>(object);
            if (fn == "isNaN") return BallDyn(std::isnan(d));
            if (fn == "isInfinite") return BallDyn(std::isinf(d));
            if (fn == "isFinite") return BallDyn(std::isfinite(d));
            if (fn == "isNegative") return BallDyn(d < 0);
            if (fn == "abs") return BallDyn(std::abs(d));
            if (fn == "toInt") return BallDyn(static_cast<int64_t>(d));
            if (fn == "toDouble") return BallDyn(d);
            if (fn == "floor") return BallDyn(static_cast<int64_t>(std::floor(d)));
            if (fn == "ceil") return BallDyn(static_cast<int64_t>(std::ceil(d)));
            if (fn == "round") return BallDyn(static_cast<int64_t>(std::round(d)));
            if (fn == "truncate") return BallDyn(static_cast<int64_t>(d));
            if (fn == "sign") return BallDyn(d > 0 ? 1 : (d < 0 ? -1 : 0));
        }
        // Function properties — return self for tear-off patterns
        if (ball_is_function(object)) {
            return object;
        }
        throw BallException("Exception"s, ("No such property: " + fn).c_str());
    }
    BallDyn _findTypeDef(auto typeName) {
        for (auto module : BallDyn(program)["modules"s]) {
            for (auto td : BallDyn(module)["typeDefs"s]) {
                if (((BallDyn(td)["name"s] == typeName) || [](const std::string& s, const std::string& e){return s.size()>=e.size() && s.compare(s.size()-e.size(),e.size(),e)==0;}(BallDyn(td)["name"s], (":"s + ball_to_string(typeName))))) {
                    auto superclass = BallDyn();
                    if (ball_has_field(td, "metadata"s)) {
                        auto sc = BallDyn(BallDyn(BallDyn(td)["metadata"s])["fields"s])["superclass"s];
                        if ((BallDyn(sc).has_value() && ball_has_field(sc, "stringValue"s))) {
                            (superclass = BallDyn(sc)["stringValue"s]);
                        }
                    }
                    auto fieldNames = std::vector<std::any>{};
                    if (ball_has_field(td, "descriptor"s)) {
                        for (auto f : BallDyn(BallDyn(td)["descriptor"s])["field"s]) {
                            fieldNames.push_back(BallDyn(f)["name"s]);
                        }
                    }
                    return std::unordered_map<std::string, std::any>{{"superclass", std::any(superclass)}, {"fieldNames", std::any(fieldNames)}};
                }
            }
        }
        return BallDyn();
    }
    BallDyn _getMetaString(auto typeDef, auto key) {
        if ((key == "superclass"s)) {
            return BallDyn(typeDef)["superclass"s];
        }
        return BallDyn();
    }
    BallDyn _buildSuperObject(auto superclass, auto childFields) {
        auto superFields = std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}, {"entry", std::any(std::unordered_map<std::string, std::any>{{"key", std::any("__type__"s)}, {"value", std::any(superclass)}})}};
        auto parentTypeDef = _findTypeDef(superclass);
        if (BallDyn(parentTypeDef).has_value()) {
            for (auto fname : BallDyn(parentTypeDef)["fieldNames"s]) {
                if ((childFields.count(fname) > 0)) {
                    ball_set(superFields, fname, BallDyn(childFields)[fname]);
                }
            }
            auto parentMethods = _resolveTypeMethods(superclass);
            if (!parentMethods.empty()) {
                ball_set(superFields, "__methods__"s, parentMethods);
            }
            auto grandparent = BallDyn(parentTypeDef)["superclass"s];
            if ((BallDyn(grandparent).has_value() && !grandparent.empty())) {
                ball_set(superFields, "__super__"s, _buildSuperObject(grandparent, childFields));
            }
        }
        return superFields;
    }
    BallDyn _resolveTypeMethods(auto typeName) {
        auto methods = std::map<std::string,std::any>{{"type_args", std::any("String, Function"s)}};
        for (auto module : BallDyn(program)["modules"s]) {
            for (auto func : BallDyn(module)["functions"s]) {
                if (ball_has_field(func, "metadata"s)) {
                    auto className = BallDyn(BallDyn(BallDyn(func)["metadata"s])["fields"s])["class"s];
                    if ((((BallDyn(className).has_value() && ball_has_field(className, "stringValue"s)) && (BallDyn(className)["stringValue"s] == typeName)) && ball_has_field(func, "body"s))) {
                        ball_set(methods, BallDyn(func)["name"s], [=](auto input) mutable {
                            return _callFunction(BallDyn(module)["name"s], func, input);
                        });
                    }
                }
            }
        }
        return methods;
    }
    BallDyn _resolveTypeMethodsWithInheritance(auto typeName) {
        auto methods = std::map<std::string,std::any>{{"type_args", std::any("String, Function"s)}};
        auto typeDef = _findTypeDef(typeName);
        if (((BallDyn(typeDef).has_value() && BallDyn(BallDyn(typeDef)["superclass"s]).has_value()) && !BallDyn(typeDef)["superclass"s].empty())) {
            auto inherited = _resolveTypeMethodsWithInheritance(BallDyn(typeDef)["superclass"s]);
            if (ball_is_map(inherited)) ball_add_all(methods, std::any_cast<const BallMap&>(inherited._val));
        }
        auto resolved = _resolveTypeMethods(typeName);
        if (ball_is_map(resolved)) ball_add_all(methods, std::any_cast<const BallMap&>(resolved._val));
        return methods;
    }
    BallDyn /* future */ _evalBlock(auto block, BallDyn& scope) {
        auto blockScope = child(scope);
        auto flowResult = BallDyn();
        auto stmts = BallDyn(block)["statements"s];
        for (auto stmt : stmts) {
            auto result = _evalStatement(stmt, blockScope);
            if (ball_is_flow_signal(result)) {
                _runScopeExits(blockScope);
                return result;
            }
        }
        if (ball_has_field(block, "result"s)) {
            (flowResult = _evalExpression(BallDyn(block)["result"s], blockScope));
        } else {
            (flowResult = BallDyn());
        }
        _runScopeExits(blockScope);
        return flowResult;
    }
    BallDyn /* future */ _runScopeExits(auto blockScope) {
        // Scope exits are not fully supported in the self-hosted C++ engine.
        // The original Dart code references `expr` and `evalScope` which are
        // not properly captured in the compiled output. This is a no-op stub.
        return BallDyn();
    }
    BallDyn /* future */ _evalStatement(auto stmt, auto& scope) {
        BallDyn s(stmt);
        // Direct field check instead of ball_which_stmt to avoid overload issues
        if (s["let"s].has_value()) {
            auto letStmt = s["let"s];
            auto name = letStmt["name"s];
            BallDyn value;
            if (ball_has_field_bd(letStmt, "value"s)) {
                // Check if value is a scope-mutating call (assign/inc/dec)
                auto valExpr = letStmt["value"s];
                if (ball_which_expr_bd(BallDyn(valExpr)) == "call"s) {
                    auto call = BallDyn(valExpr)["call"s];
                    std::string fn = static_cast<std::string>(BallDyn(call)["function"s]);
                    std::string mod = static_cast<std::string>(BallDyn(call)["module"s]);
                    if ((mod == "std" || mod == "dart_std" || mod.empty()) &&
                        (fn == "pre_increment" || fn == "post_increment" ||
                         fn == "pre_decrement" || fn == "post_decrement")) {
                        value = _evalIncDecRef(call, scope);
                    } else if ((mod == "std" || mod == "dart_std" || mod.empty()) && fn == "assign") {
                        value = _evalAssignRef(call, scope);
                    } else {
                        value = _evalExpression(valExpr, scope);
                    }
                } else {
                    value = _evalExpression(letStmt["value"s], scope);
                }
            }
            std::string nameStr = ball_to_string(name._val);
            // Use BallDyn::set directly to avoid bind overload resolution issues
            if constexpr (std::is_same_v<std::remove_reference_t<decltype(scope)>, BallDyn> ||
                          std::is_base_of_v<BallDyn, std::remove_reference_t<decltype(scope)>>) {
                scope.set(nameStr, value._val);
            } else {
                // Fallback for std::any scope
                if (scope.type() == typeid(BallMap)) {
                    std::any_cast<BallMap&>(scope)[nameStr] = value._val;
                }
            }
            return BallDyn();
        }
        if (s["expression"s].has_value()) {
            // Check if expression is a scope-mutating call (assign/increment/decrement)
            // that needs direct scope reference access
            auto expr = s["expression"s];
            if (ball_which_expr_bd(BallDyn(expr)) == "call"s) {
                auto call = BallDyn(expr)["call"s];
                std::string mod = static_cast<std::string>(BallDyn(call)["module"s]);
                std::string fn = static_cast<std::string>(BallDyn(call)["function"s]);
                if ((mod == "std" || mod == "dart_std" || mod.empty()) &&
                    (fn == "assign" || fn == "pre_increment" || fn == "post_increment" ||
                     fn == "pre_decrement" || fn == "post_decrement")) {
                    if (fn == "assign") return _evalAssignRef(call, scope);
                    return _evalIncDecRef(call, scope);
                }
            }
            // For block expressions, evaluate with scope reference for mutation propagation
            auto expr2 = s["expression"s];
            if (ball_which_expr_bd(BallDyn(expr2)) == "block"s) {
                return _evalBlockRef(BallDyn(expr2)["block"s], scope);
            }
            return _evalExpression(s["expression"s], scope);
        }
        return BallDyn();
    }
    // Block evaluation with scope reference — propagates parent scope mutations
    BallDyn _evalBlockRef(auto block, auto& scope) {
        auto blockScope = child(scope);
        auto flowResult = BallDyn();
        auto stmts = BallDyn(block)["statements"s];
        for (auto stmt : stmts) {
            auto result = _evalStatement(stmt, blockScope);
            if (ball_is_flow_signal(result)) {
                _propagateParentChanges(blockScope, scope);
                return result;
            }
        }
        if (ball_has_field(block, "result"s)) {
            (flowResult = _evalExpression(BallDyn(block)["result"s], blockScope));
        }
        _propagateParentChanges(blockScope, scope);
        return flowResult;
    }
    // Propagate changes from blockScope's __parent__ back to the actual parent scope
    void _propagateParentChanges(auto& blockScope, auto& parentScope) {
        if constexpr (std::is_same_v<std::remove_reference_t<decltype(blockScope)>, BallDyn> ||
                      std::is_base_of_v<BallDyn, std::remove_reference_t<decltype(blockScope)>>) {
            if (blockScope._val.type() != typeid(BallMap)) return;
            auto& bm = std::any_cast<BallMap&>(blockScope._val);
            auto pit = bm.find("__parent__");
            if (pit == bm.end() || !pit->second.has_value()) return;
            if (pit->second.type() != typeid(BallMap)) return;
            auto& parentCopy = std::any_cast<const BallMap&>(pit->second);
            // Copy all non-internal keys from the parent copy back to the actual parent
            for (auto pcit = parentCopy.begin(); pcit != parentCopy.end(); ++pcit) {
                if (pcit->first.rfind("__", 0) == 0) continue;  // Skip internal keys
                if (pcit->first == "type_args") continue;
                set_in_scope(_scopeAny(parentScope), pcit->first, pcit->second);
            }
        }
    }
    // Helper: get mutable reference to the scope's underlying std::any
    static std::any& _scopeAny(BallDyn& scope) { return scope._val; }
    static std::any& _scopeAny(std::any& scope) { return scope; }

    // Assign with scope reference — ensures mutations propagate
    BallDyn _evalAssignRef(auto call, auto& scope) {
        auto fields = _lazyFields(call);
        auto target = BallDyn(fields)["target"s];
        auto value = BallDyn(fields)["value"s];
        if ((!BallDyn(target).has_value() || !BallDyn(value).has_value())) {
            return BallDyn();
        }
        auto op = _stringFieldVal(fields, "op"s);
        if ((op == "??="s)) {
            return _evalNullAwareAssign(target, value, scope);
        }
        auto val = _evalExpression(value, scope);
        if ((ball_which_expr(target) == "reference"s)) {
            auto name = BallDyn(BallDyn(target)["reference"s])["name"s];
            std::string nameStr = static_cast<std::string>(name);
            if (((BallDyn(op).has_value() && !op.empty()) && (op != "="s))) {
                auto current = lookup(scope, name);
                auto computed = _applyCompoundOp(op, current, val);
                set_in_scope(_scopeAny(scope), nameStr, computed._val);
                return computed;
            }
            set_in_scope(_scopeAny(scope), nameStr, val._val);
            return val;
        }
        // For non-reference targets (fieldAccess, index), delegate to the regular path
        return _evalAssign(call, scope);
    }
    // Increment/decrement with scope reference
    BallDyn _evalIncDecRef(auto call, auto& scope) {
        auto fields = _lazyFields(call);
        auto valueExpr = BallDyn(fields)["value"s];
        if (!BallDyn(valueExpr).has_value()) {
            return BallDyn();
        }
        std::string fnStr = static_cast<std::string>(BallDyn(call)["function"s]);
        bool isInc = (fnStr.find("increment") != std::string::npos);
        bool isPre = (fnStr.rfind("pre", 0) == 0);
        if ((ball_which_expr(valueExpr) == "reference"s)) {
            auto name = BallDyn(BallDyn(valueExpr)["reference"s])["name"s];
            std::string nameStr = static_cast<std::string>(name);
            auto current = lookup(scope, name);
            BallDyn updated;
            if (isInc) updated = current + 1LL;
            else updated = current - 1LL;
            set_in_scope(_scopeAny(scope), nameStr, updated._val);
            if (isPre) return updated;
            return current;
        }
        // Delegate to non-reference path
        return _evalIncDec(call, scope);
    }
    BallDyn _evalLambda(auto func, BallDyn& scope) {
        return BallDyn(BallFunc([=, this](std::any inputAny) mutable -> std::any {
            BallDyn input(inputAny);
            auto lambdaScope = child(scope);
            bind(lambdaScope, "input"s, input._val);
            auto paramNames = (BallDyn(ball_has_field(func, "metadata"s) ? BallDyn(_extractParams(BallDyn(func)["metadata"s])) : BallDyn(std::vector<std::any>{})));
            if (static_cast<int64_t>(paramNames.size()) == 1LL && !ball_is_map(input)) {
                bind(lambdaScope, paramNames.front(), input._val);
            }
            if (ball_is_map(input)) {
                for (int64_t i = 0; i < static_cast<int64_t>(paramNames.size()); i++) {
                    auto pName = BallDyn(paramNames)[i];
                    if (input.count(pName) > 0) bind(lambdaScope, pName, BallDyn(input)[pName]._val);
                    else if (input.count("arg"s + ball_to_string(i)) > 0)
                        bind(lambdaScope, pName, BallDyn(input)["arg"s + ball_to_string(i)]._val);
                }
            }
            if (!ball_has_field(func, "body"s)) return std::any{};
            auto result = _evalExpression(BallDyn(func)["body"s], lambdaScope);
            if (ball_is_flow_signal(result) && BallDyn(result)["kind"s] == "return"s)
                return BallDyn(result)["value"s]._val;
            return result._val;
        }));
    }
    BallDyn _lazyFields(auto call) {
        if (((!ball_has_field(call, "input"s)) || (ball_which_expr(BallDyn(call)["input"s]) != "messageCreation"s))) {
            return std::vector<std::any>{};
        }
        auto result = std::map<std::string,std::any>{{"type_args", std::any("String, Expression"s)}};
        for (auto f : BallDyn(BallDyn(BallDyn(call)["input"s])["messageCreation"s])["fields"s]) {
            std::string key = static_cast<std::string>(BallDyn(f)["name"s]);
            result[key] = BallDyn(f)["value"s]._val;
        }
        return result;
    }
    BallDyn /* future */ _evalLazyIf(auto call, BallDyn& scope) {
        auto fields = _lazyFields(call);
        auto condition = BallDyn(fields)["condition"s];
        auto thenBranch = BallDyn(fields)["then"s];
        auto elseBranch = BallDyn(fields)["else"s];
        if ((!BallDyn(condition).has_value() || !BallDyn(thenBranch).has_value())) {
            throw BallException("Exception"s, "Exception"s, std::map<std::string, std::string>{{"arg0"s, "std.if missing condition or then"s}});
        }
        auto condVal = _evalExpression(condition, scope);
        if (_toBool(condVal)) {
            return _evalExpression(thenBranch, scope);
        } else {
            if (BallDyn(elseBranch).has_value()) {
                return _evalExpression(elseBranch, scope);
            }
        }
        return BallDyn();
    }
    BallDyn /* future */ _evalLazyFor(auto call, BallDyn& scope) {
        auto fields = _lazyFields(call);
        auto initExpr = BallDyn(fields)["init"s];
        auto condition = BallDyn(fields)["condition"s];
        auto update = BallDyn(fields)["update"s];
        auto body = BallDyn(fields)["body"s];
        auto forScope = child(scope);
        if (BallDyn(initExpr).has_value()) {
            if ((ball_which_expr(initExpr) == "block"s)) {
                for (auto stmt : BallDyn(BallDyn(initExpr)["block"s])["statements"s]) {
                    _evalStatement(stmt, forScope);
                }
            } else {
                if (((ball_which_expr(initExpr) == "literal"s) && ball_has_field(BallDyn(initExpr)["literal"s], "stringValue"s))) {
                    auto s = BallDyn(BallDyn(initExpr)["literal"s])["stringValue"s];
                    auto match = ball_first_match(std::regex("(?:var|final|int|double|String)\\s+(\\w+)\\s*=\\s*(.+)"s), s);
                    if (BallDyn(match).has_value()) {
                        auto varName = ball_group(match, 1LL);
                        auto rawVal = [](const std::string& s){auto a=s.find_first_not_of(" \t\n\r"),b=s.find_last_not_of(" \t\n\r");return a==std::string::npos?std::string():s.substr(a,b-a+1);}(ball_group(match, 2LL));
                        auto intParsed = ball_try_parse("int"s, rawVal);
                        auto dblParsed = ball_try_parse("double"s, rawVal);
                        BallDyn parsed;
                        if (BallDyn(intParsed).has_value()) parsed = BallDyn(intParsed);
                        else if (BallDyn(dblParsed).has_value()) parsed = BallDyn(dblParsed);
                        else if (rawVal == "true"s) parsed = BallDyn(true);
                        else if (rawVal == "false"s) parsed = BallDyn(false);
                        else parsed = BallDyn(rawVal);
                        bind(forScope, varName, parsed._val);
