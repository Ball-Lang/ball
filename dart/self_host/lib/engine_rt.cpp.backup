    BallDyn _stdRecord(auto input) {
        if (!(ball_is_map(input))) {
            return input;
        }
        return BallDyn(BallDyn(input)["fields"s] ? BallDyn(BallDyn(input)["fields"s]) : BallDyn(input));
    }
    BallDyn _stdSwitchExpr(auto input) {
        if (!(ball_is_map(input))) {
            return BallDyn();
        }
        auto subject = BallDyn(input)["subject"s];
        auto cases = BallDyn(input)["cases"s];
        if (!(ball_is_list(cases))) {
            return BallDyn();
        }
        auto defaultBody = BallDyn();
        for (auto c : cases) {
            if (!(ball_is_map(c))) {
                continue;
            }
            auto pattern = BallDyn(c)["pattern"s];
            auto body = BallDyn(c)["body"s];
            auto guard = BallDyn(c)["guard"s];
            if ((!BallDyn(pattern).has_value() || (pattern == "_"s))) {
                (defaultBody = body);
                continue;
            }
            auto bindings = std::map<std::string,std::any>{{"type_args", std::any("String, Object?"s)}};
            if (_matchPattern(subject, pattern, bindings)) {
                if ((BallDyn(guard).has_value() && ball_is_function(guard))) {
                    auto guardResult = guard(bindings);
                    if (ball_object_type_matches(guardResult, "Future"s)) {
                        (guardResult = guardResult);
                    }
                    if ((guardResult != true)) {
                        continue;
                    }
                }
                if (ball_is_function(body)) {
                    auto result = body(bindings);
                    if (ball_object_type_matches(result, "Future"s)) {
                        (result = result);
                    }
                    return result;
                }
                return body;
            }
        }
        return defaultBody;
    }
    bool _matchPattern(auto value, auto pattern, auto bindings) {
        if ((!BallDyn(pattern).has_value() || (pattern == "_"s))) {
            return true;
        }
        if (ball_is_string(pattern)) {
            return _matchStringPattern(value, pattern, bindings);
        }
        if (ball_is_map(pattern)) {
            return _matchStructuredPattern(value, pattern, bindings);
        }
        return ((pattern == value) || (ball_to_string(pattern) == value));
    }
    bool _matchStringPattern(auto value, auto pattern, auto bindings) {
        auto trimmed = [](const std::string& s){auto a=s.find_first_not_of(" \t\n\r"),b=s.find_last_not_of(" \t\n\r");return a==std::string::npos?std::string():s.substr(a,b-a+1);}(pattern);
        if ((trimmed == "_"s)) {
            return true;
        }
        auto typeBindMatch = ball_first_match(std::regex("^(\\w+)\\s+(\\w+)$"s), trimmed);
        if (BallDyn(typeBindMatch).has_value()) {
            auto typeName = ball_group(typeBindMatch, 1LL);
            auto varName = ball_group(typeBindMatch, 2LL);
            if (_matchesTypePattern(value, typeName)) {
                ball_set(bindings, varName, value);
                return true;
            }
            return false;
        }
        if ((trimmed == "null"s)) {
            return !BallDyn(value).has_value();
        }
        if ((trimmed == "true"s)) {
            return (value == true);
        }
        if ((trimmed == "false"s)) {
            return (value == false);
        }
        auto relMatch = ball_first_match(std::regex("^(==|!=|>=|<=|>|<)\\s*(.+)$"s), trimmed);
