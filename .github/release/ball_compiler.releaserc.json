{
  "branches": ["main"],
  "tagFormat": "ball_compiler-v${version}",
  "plugins": [
    ["./tools/release/only-package-commits.mjs", { "paths": ["dart/compiler"] }],
    ["@semantic-release/changelog", { "changelogFile": "dart/compiler/CHANGELOG.md" }],
    ["@semantic-release/exec", {
      "prepareCmd": "node tools/release/set_manifest_version.mjs --format=pubspec --file=dart/compiler/pubspec.yaml --version=${nextRelease.version}",
      "publishCmd": "gh workflow run release-publish.yml --ref ball_compiler-v${nextRelease.version}"
    }],
    ["@semantic-release/git", {
      "assets": ["dart/compiler/pubspec.yaml", "dart/compiler/CHANGELOG.md"],
      "message": "chore(release): ball_compiler ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/github", { "successComment": false }]
  ]
}
