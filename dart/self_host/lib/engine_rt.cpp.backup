                        return computed;
                    }
                    if ((ball_is_map(list) && ball_is_string(idx))) {
                        auto current = BallDyn(list)[idx];
                        auto computed = _applyCompoundOp(op, current, val);
                        ball_set(list, idx, computed);
                        return computed;
                    }
                }
                if ((ball_is_list(list) && ball_is_int(idx))) {
                    ball_set(list, idx, val);
                    return val;
                }
                if ((ball_is_map(list) && ball_is_string(idx))) {
                    ball_set(list, idx, val);
                    return val;
                }
            }
        }
        return val;
