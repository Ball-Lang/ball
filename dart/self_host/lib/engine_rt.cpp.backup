                    auto computed = _applyCompoundOp(op, current, val);
                    ball_set(obj, fieldName, computed);
                    return computed;
                }
                auto setterResult = _trySetterDispatch(obj, fieldName, val);
                if ((setterResult != BallDyn())) {
                    return setterResult;
                }
                ball_set(obj, fieldName, val);
                return val;
